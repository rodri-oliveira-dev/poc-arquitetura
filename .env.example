# Valores ficticios e descartaveis para desenvolvimento local.
# Copie para .env apenas se quiser sobrescrever os defaults locais do compose.
# Nao reutilize estes valores em ambientes compartilhados, homologacao ou producao.

POSTGRES_PASSWORD=local_dev_password
GRAFANA_ADMIN_PASSWORD=local_dev_password
AUTH_POC_USERNAME=local_user
AUTH_POC_PASSWORD=local_password
AUTH_POC_SCOPE=ledger.write balance.read
