# Exemplo de variaveis locais descartaveis.
# Prefira copiar .env.local.example para .env.local ao usar docker compose --env-file.
# Copie para .env apenas se quiser usar fluxos antigos que dependem do carregamento automatico do Compose.
# Nao reutilize estes valores em ambientes compartilhados, homologacao ou producao.

POSTGRES_PASSWORD=<POSTGRES_PASSWORD>
POSTGRES_HOST_PORT=15432
LEDGER_DB_PASSWORD=<LEDGER_DB_PASSWORD>
LEDGER_DB_MIGRATOR_PASSWORD=<LEDGER_DB_MIGRATOR_PASSWORD>
BALANCE_DB_READ_PASSWORD=<BALANCE_DB_READ_PASSWORD>
BALANCE_DB_WRITE_PASSWORD=<BALANCE_DB_WRITE_PASSWORD>
BALANCE_DB_MIGRATOR_PASSWORD=<BALANCE_DB_MIGRATOR_PASSWORD>
TRANSFER_DB_PASSWORD=<TRANSFER_DB_PASSWORD>
TRANSFER_DB_MIGRATOR_PASSWORD=<TRANSFER_DB_MIGRATOR_PASSWORD>
IDENTITY_DB_PASSWORD=identity-local-password
IDENTITY_DB_MIGRATOR_PASSWORD=<IDENTITY_DB_MIGRATOR_PASSWORD>
IDENTITY_SERVICE_HOST_PORT=5232
IDENTITY_SERVICE_CONNECTION_STRING=Host=127.0.0.1;Port=15432;Database=appdb;Username=identity_migrator_user;Password=<IDENTITY_DB_MIGRATOR_PASSWORD>
GRAFANA_ADMIN_PASSWORD=<GRAFANA_ADMIN_PASSWORD>
SONAR_HOST_PORT=9000
SONAR_DB_NAME=sonarqube
SONAR_DB_USER=sonar
SONAR_DB_PASSWORD=<SONAR_DB_PASSWORD>
TOKEN_PROVIDER=keycloak
JWT_ISSUER=http://localhost:8081/realms/poc
JWT_JWKS_URL=http://keycloak:8080/realms/poc/protocol/openid-connect/certs
JWT_REQUIRE_HTTPS_METADATA=false
KEYCLOAK_HOST_PORT=8081
KEYCLOAK_BASE_URL=http://localhost:8081
KEYCLOAK_INTERNAL_BASE_URL=http://keycloak:8080
KEYCLOAK_REALM=poc
KEYCLOAK_TOKEN_ENDPOINT=/realms/poc/protocol/openid-connect/token
KEYCLOAK_CLIENT_ID=poc-automation
KEYCLOAK_CLIENT_SECRET=<KEYCLOAK_CLIENT_SECRET>
KEYCLOAK_IDENTITY_ADMIN_CLIENT_ID=identity-service-admin
KEYCLOAK_SCOPE=
TRANSFER_WORKER_LEDGER_AUTH_SCOPE=ledger.write
KEYCLOAK_BOOTSTRAP_ADMIN_USERNAME=local_admin
KEYCLOAK_BOOTSTRAP_ADMIN_PASSWORD=<KEYCLOAK_BOOTSTRAP_ADMIN_PASSWORD>
KEYCLOAK_LOCAL_LEDGER_USER_PASSWORD=<KEYCLOAK_LOCAL_LEDGER_USER_PASSWORD>
KEYCLOAK_LOCAL_BALANCE_USER_PASSWORD=<KEYCLOAK_LOCAL_BALANCE_USER_PASSWORD>
KEYCLOAK_LOCAL_ADMIN_USER_PASSWORD=<KEYCLOAK_LOCAL_ADMIN_USER_PASSWORD>
MAILPIT_SMTP_HOST_PORT=1025
MAILPIT_UI_HOST_PORT=8025
Email__Provider=Mailpit
Email__AuthenticationUrl=http://localhost:8081/realms/poc/account
Mailpit__Host=localhost
Mailpit__Port=1025
Mailpit__EnableSsl=false
Mailpit__From=noreply@poc-arquitetura.local
Mailpit__FromName=POC-Arquitetura
Resend__ApiKey=<RESEND_API_KEY>
Resend__From=onboarding@seudominio.example
Resend__FromName=POC-Arquitetura
Resend__ReplyTo=
PUBSUB_EMULATOR_HOST_PORT=8085
PUBSUB_PROJECT_ID=poc-local
PUBSUB_LEDGER_EVENTS_TOPIC_ID=ledger.ledgerentry.created.local
PUBSUB_LEDGER_EVENTS_DLQ_TOPIC_ID=ledger.ledgerentry.created.dlq.local
PUBSUB_BALANCE_SUBSCRIPTION_ID=balance-service-ledger-events-local
PUBSUB_LEDGER_EVENTS_DLQ_INSPECTION_SUBSCRIPTION_ID=ledger-events-application-dlq-inspection-local

# Placeholders nao secretos para debug local e smoke manual com Cloud SQL Auth Proxy.
# GOOGLE_APPLICATION_CREDENTIALS deve apontar para um arquivo local ignorado pelo Git,
# como ADC do gcloud ou chave JSON de service account aprovada para desenvolvimento.
CLOUDSQL_INSTANCE_CONNECTION_NAME=project-id:region:instance-name
CLOUDSQL_LOCAL_HOST=127.0.0.1
CLOUDSQL_LOCAL_PORT=5432
CLOUDSQL_PROXY_HOST_PORT=5432
CLOUDSQL_DATABASE=appdb
CLOUDSQL_USERNAME=app_user
GOOGLE_APPLICATION_CREDENTIALS=./secrets/cloudsql/application_default_credentials.json
DATABASE_NAME=appdb
DATABASE_USER=app_user
DATABASE_PASSWORD=<DATABASE_PASSWORD>

# Variaveis usadas somente pelo overlay legado compose.auth-legacy.yaml.
AUTH_POC_USERNAME=local_user
AUTH_POC_PASSWORD=<AUTH_POC_PASSWORD>
AUTH_POC_SCOPE=ledger.write balance.read
