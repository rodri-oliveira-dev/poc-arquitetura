#!/usr/bin/env sh
set -eu

if command -v git >/dev/null 2>&1; then
  repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
else
  repo_root="$(pwd)"
fi

cd "$repo_root"

if ! command -v dotnet >/dev/null 2>&1; then
  echo "post-merge: dotnet nao encontrado; restore nao executado." >&2
  exit 0
fi

echo "==> post-merge: restaurando tools locais"
dotnet tool restore

echo "==> post-merge: restaurando dependencias da solution"
dotnet restore ./PocArquitetura.slnx

echo "==> post-merge: restore concluido"
