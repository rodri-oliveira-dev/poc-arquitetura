append_dotnet_format_file() {
  changed_file="$1"
  format_files_path="$2"

  case "$changed_file" in
    *.cs)
      if [ -f "$changed_file" ]; then
        printf '%s\n' "$changed_file" >>"$format_files_path"
      fi
      ;;
  esac
}

append_context_dotnet_format_files_to_aggregate() {
  for format_files_path in \
    "$audit_dotnet_format_files" \
    "$balance_dotnet_format_files" \
    "$identity_dotnet_format_files" \
    "$ledger_dotnet_format_files" \
    "$payment_dotnet_format_files" \
    "$transfer_dotnet_format_files"
  do
    if [ -s "$format_files_path" ]; then
      cat "$format_files_path" >>"$aggregate_dotnet_format_files"
    fi
  done
}

run_dotnet_format_context() {
  context_name="$1"
  solution_path="$2"
  format_files_path="$3"

  if [ "$dotnet_format_check" = true ] && [ -s "$format_files_path" ]; then
    dotnet_format_file_count="$(count_dotnet_format_files "$format_files_path")"
    if [ "$dotnet_format_file_count" -gt "$DOTNET_FORMAT_FILE_LIMIT" ]; then
      echo "==> pre-push: $dotnet_format_file_count arquivos .cs $context_name alterados excedem o limite local de $DOTNET_FORMAT_FILE_LIMIT; formatacao .NET $context_name local ignorada"
    else
      run_timed "formatacao dos arquivos .cs $context_name alterados" run_dotnet_format_changed_files "$solution_path" "$format_files_path"
    fi
  elif [ "$dotnet_format_check" = false ]; then
    echo "==> pre-push: diff inseguro; formatacao .NET $context_name local ignorada"
  else
    echo "==> pre-push: sem arquivos .cs $context_name alterados; formatacao .NET $context_name local ignorada"
  fi
}

restore_solution() {
  context_name="$1"
  solution_path="$2"

  run_timed "restore .NET $context_name" dotnet restore "$solution_path"
}

build_solution() {
  context_name="$1"
  solution_path="$2"

  run_timed "build .NET $context_name ($CONFIGURATION)" dotnet build "$solution_path" --configuration "$CONFIGURATION" --no-restore
}

test_solution() {
  context_name="$1"
  solution_path="$2"

  run_timed "testes unitarios rapidos $context_name sem cobertura" dotnet test "$solution_path" \
    --configuration "$CONFIGURATION" \
    --no-build \
    --no-restore \
    --filter "$UNIT_TEST_FILTER"
}

run_container_baseline_validator() {
  dotnet run --project ./tools/ContainerBaselineValidator/ContainerBaselineValidator.csproj -- --root .
}

run_compose_config_validation() {
  if command -v bash >/dev/null 2>&1; then
    bash ./scripts/quality/containers/validate-compose-configs.sh
    return "$?"
  fi

  ./scripts/quality/containers/validate-compose-configs.sh
}

run_container_validations() {
  if [ "$dockerfile_changes" = true ]; then
    if command -v dotnet >/dev/null 2>&1; then
      run_timed "baseline estatico de Dockerfiles e Compose" run_container_baseline_validator
    else
      echo "==> pre-push: .NET SDK nao encontrado; baseline estatico de containers local ignorado"
      echo "==> pre-push: validacao nao executada: ContainerBaselineValidator"
      echo "==> pre-push: gate bloqueante de container baseline continua no Pull Request/GitHub Actions"
    fi
  fi

  if [ "$compose_changes" = true ]; then
    if command -v docker >/dev/null 2>&1 && docker compose version >/dev/null 2>&1; then
      run_timed "configuracoes Docker Compose suportadas" run_compose_config_validation
    else
      echo "==> pre-push: Docker CLI com suporte a 'docker compose' nao encontrado; validacao local de Compose ignorada"
      echo "==> pre-push: validacao nao executada: scripts/quality/containers/validate-compose-configs.sh"
      echo "==> pre-push: gate bloqueante de Compose continua no Pull Request/GitHub Actions"
    fi
  fi
}

