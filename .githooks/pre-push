#!/usr/bin/env sh
set -eu

CONFIGURATION="${CONFIGURATION:-Release}"
COVERAGE_THRESHOLD="${COVERAGE_THRESHOLD:-85}"
FULL_TESTS="${FULL_TESTS:-false}"
UNIT_TEST_FILTER="${UNIT_TEST_FILTER:-Category!=Integration&Category!=Container&Category!=Contract}"

if command -v git >/dev/null 2>&1; then
  repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
else
  repo_root="$(pwd)"
fi

cd "$repo_root"

find_python() {
  if command -v python3 >/dev/null 2>&1; then
    command -v python3
    return 0
  fi

  if command -v python >/dev/null 2>&1; then
    command -v python
    return 0
  fi

  return 1
}

make_temp_file() {
  name="$1"
  if command -v mktemp >/dev/null 2>&1; then
    mktemp "${TMPDIR:-/tmp}/$name.XXXXXX"
  else
    path="${TMPDIR:-/tmp}/$name.$$"
    : >"$path"
    printf '%s\n' "$path"
  fi
}

run_timed() {
  step_name="$1"
  shift

  start_time="$(date +%s)"
  echo "==> pre-push: iniciando $step_name"

  set +e
  "$@"
  status="$?"
  set -e

  end_time="$(date +%s)"
  duration="$((end_time - start_time))"

  if [ "$status" -ne 0 ]; then
    echo "==> pre-push: $step_name falhou em ${duration}s"
    exit "$status"
  fi

  echo "==> pre-push: $step_name finalizado em ${duration}s"
}

run_dotnet_step() {
  step="$1"
  solution="$2"
  shift 2

  command_text="$*"
  echo "==> pre-push: iniciando $step .NET $solution"

  set +e
  "$@"
  status="$?"
  set -e

  if [ "$status" -ne 0 ]; then
    echo "pre-push bloqueado"
    echo "etapa: $step"
    echo "solution: $solution"
    echo "comando: $command_text"
    return "$status"
  fi
}

clean_solution_name() {
  printf '%s' "$1" | tr -d '\r' | sed '1s/^\xef\xbb\xbf//'
}

run_full_tests() {
  if ! command -v bash >/dev/null 2>&1; then
    echo "==> pre-push: FULL_TESTS=true exige bash para executar ./test.sh" >&2
    exit 1
  fi

  bash ./test.sh "$CONFIGURATION" "$COVERAGE_THRESHOLD"
}

is_full_tests_requested() {
  case "$FULL_TESTS" in
    true|TRUE|1|yes|YES)
      return 0
      ;;
  esac

  return 1
}

run_requested_full_tests() {
  echo "==> pre-push: FULL_TESTS=true; executando validacao completa oficial com cobertura"
  run_timed "testes completos com cobertura" run_full_tests
  echo "==> pre-push: validacao completa aprovada"
}

run_container_baseline_validator() {
  dotnet run --project ./tools/ContainerBaselineValidator/ContainerBaselineValidator.csproj -- --root .
}

run_compose_config_validation() {
  if command -v bash >/dev/null 2>&1; then
    bash ./scripts/quality/containers/validate-compose-configs.sh
    return "$?"
  fi

  ./scripts/quality/containers/validate-compose-configs.sh
}

run_container_validations() {
  if [ "$dockerfile_changes" = true ]; then
    if command -v dotnet >/dev/null 2>&1; then
      run_timed "baseline estatico de Dockerfiles e Compose" run_container_baseline_validator
    else
      echo "==> pre-push: .NET SDK nao encontrado; baseline estatico de containers local ignorado"
      echo "==> pre-push: validacao nao executada: ContainerBaselineValidator"
      echo "==> pre-push: gate bloqueante de container baseline continua no Pull Request/GitHub Actions"
    fi
  fi

  if [ "$compose_changes" = true ]; then
    if command -v docker >/dev/null 2>&1 && docker compose version >/dev/null 2>&1; then
      run_timed "configuracoes Docker Compose suportadas" run_compose_config_validation
    else
      echo "==> pre-push: Docker CLI com suporte a 'docker compose' nao encontrado; validacao local de Compose ignorada"
      echo "==> pre-push: validacao nao executada: scripts/quality/containers/validate-compose-configs.sh"
      echo "==> pre-push: gate bloqueante de Compose continua no Pull Request/GitHub Actions"
    fi
  fi
}

is_documentation_or_nonimpacting_path() {
  case "$1" in
    README.md|docs/*|*.md|*.png|*.jpg|*.jpeg|*.gif|*.svg|*.webp)
      return 0
      ;;
  esac

  return 1
}

is_ci_only_path() {
  case "$1" in
    .github/workflows/*|.github/actions/*|coverlet.runsettings|test.sh|test.ps1)
      return 0
      ;;
  esac

  return 1
}

is_dockerfile_path() {
  case "$1" in
    Dockerfile|*/Dockerfile|Dockerfile.*|*/Dockerfile.*)
      return 0
      ;;
  esac

  return 1
}

is_compose_path() {
  case "$1" in
    compose.yaml|compose.yml|compose.*.yaml|compose.*.yml|*/compose.yaml|*/compose.yml|*/compose.*.yaml|*/compose.*.yml)
      return 0
      ;;
  esac

  return 1
}

is_container_baseline_validation_path() {
  case "$1" in
    tools/ContainerBaselineValidator/*|.dockerignore|global.json|Directory.Build.props|Directory.Packages.props)
      return 0
      ;;
  esac

  return 1
}

is_compose_validation_path() {
  case "$1" in
    scripts/quality/containers/validate-compose-configs.sh|scripts/quality/containers/validate-compose-configs.ps1|scripts/lib/common.sh|scripts/lib/common.ps1|.env.local.example)
      return 0
      ;;
  esac

  return 1
}

is_terraform_impacting_path() {
  case "$1" in
    infra/terraform/*.tf|infra/terraform/*.tfvars|infra/terraform/**/*.tf|infra/terraform/**/*.tfvars|*.tf|*.tfvars)
      return 0
      ;;
  esac

  return 1
}

is_potential_dotnet_path() {
  case "$1" in
    *.cs|*.csproj|*.props|*.targets|*.sln|*.slnx|global.json|NuGet.config|Directory.Packages.props|.editorconfig|.globalconfig|.githooks/pre-push|src/*|tests/*|tools/*|contracts/events/*)
      return 0
      ;;
  esac

  return 1
}

mark_conservative_fallback_required() {
  echo "==> pre-push: executando validacoes conservadoras"
  dotnet_changes=true
  terraform_changes=true
  dockerfile_changes=true
  compose_changes=true
  container_changes=true
  : >"$changed_file_records"
  printf 'M\0Directory.Build.props\0' >>"$changed_file_records"
  printf 'M\0PocArquitetura.slnx\0' >>"$changed_file_records"
}

changed_file_records="$(make_temp_file pre-push-changed-records)"
changed_files="$(make_temp_file pre-push-changed)"
impacted_solutions="$(make_temp_file pre-push-solutions)"

trap 'rm -f "$changed_file_records" "$changed_files" "$impacted_solutions"' EXIT

diff_is_safe=true

echo "==> pre-push: analisando alteracoes pendentes de push"

python_cmd="$(find_python || true)"
if [ -z "$python_cmd" ]; then
  echo "==> pre-push: Python nao encontrado; nao foi possivel identificar arquivos do push com registros NUL" >&2
  diff_is_safe=false
elif ! "$python_cmd" ./scripts/ci/collect-pre-push-files.py --output "$changed_file_records" --paths-output "$changed_files" 2>&1; then
  diff_is_safe=false
  : >"$changed_files"
fi

dotnet_changes=false
terraform_changes=false
dockerfile_changes=false
compose_changes=false
container_changes=false
dotnet_tool_manifest_changes=false

if [ "$diff_is_safe" = false ]; then
  echo "==> pre-push: validacoes serao executadas por seguranca"
  mark_conservative_fallback_required
else
  while IFS= read -r changed_file
  do
    [ -n "$changed_file" ] || continue

    changed_file_classified=false

    if is_documentation_or_nonimpacting_path "$changed_file"; then
      changed_file_classified=true
      echo "==> pre-push: alteracao documental ou nao impactante detectada em $changed_file"
    fi

    if is_ci_only_path "$changed_file"; then
      changed_file_classified=true
      echo "==> pre-push: arquivo validado exclusivamente no CI reconhecido em $changed_file"
      echo "==> pre-push: nenhuma validacao local sera executada para $changed_file"
      echo "==> pre-push: gate correspondente permanece no Pull Request/GitHub Actions"
    fi

    if is_terraform_impacting_path "$changed_file"; then
      changed_file_classified=true
      terraform_changes=true
      echo "==> pre-push: alteracao Terraform detectada em $changed_file"
    fi

    if is_dockerfile_path "$changed_file"; then
      changed_file_classified=true
      dockerfile_changes=true
      container_changes=true
      echo "==> pre-push: alteracao de Dockerfile detectada em $changed_file"
    fi

    if is_compose_path "$changed_file"; then
      changed_file_classified=true
      compose_changes=true
      container_changes=true
      echo "==> pre-push: alteracao Docker Compose detectada em $changed_file"
    fi

    if is_container_baseline_validation_path "$changed_file"; then
      changed_file_classified=true
      dockerfile_changes=true
      container_changes=true
      echo "==> pre-push: alteracao em validacao de container baseline detectada em $changed_file"
    fi

    if is_compose_validation_path "$changed_file"; then
      changed_file_classified=true
      compose_changes=true
      container_changes=true
      echo "==> pre-push: alteracao em validacao Docker Compose detectada em $changed_file"
    fi

    case "$changed_file" in
      dotnet-tools.json|.config/dotnet-tools.json)
        changed_file_classified=true
        dotnet_tool_manifest_changes=true
        echo "==> pre-push: alteracao de manifesto de ferramenta .NET detectada em $changed_file"
        ;;
    esac

    if is_potential_dotnet_path "$changed_file"; then
      changed_file_classified=true
      dotnet_changes=true
    fi

    if [ "$changed_file_classified" = false ]; then
      echo "==> pre-push: arquivo sem classificacao de impacto: $changed_file"
      diff_is_safe=false
    fi
  done <"$changed_files"

  if [ "$diff_is_safe" = false ]; then
    mark_conservative_fallback_required
  fi

  if [ "$dotnet_changes" = false ] && [ "$terraform_changes" = false ] && [ "$dotnet_tool_manifest_changes" = false ] && [ "$container_changes" = false ]; then
    if is_full_tests_requested; then
      run_requested_full_tests
      exit 0
    fi

    echo "==> pre-push: nenhuma alteracao localmente impactante detectada; pulando validacoes locais"
    echo "==> pre-push: gates pesados continuam no Pull Request/GitHub Actions"
    exit 0
  fi
fi

if [ "$container_changes" = true ]; then
  run_container_validations
fi

if [ "$terraform_changes" = true ]; then
  if command -v terraform >/dev/null 2>&1; then
    run_timed "formatacao Terraform" terraform fmt -check -recursive "$repo_root/infra/terraform"
  else
    echo "==> pre-push: Terraform CLI nao encontrado; fmt local ignorado"
    echo "==> pre-push: terraform validate completo roda no Pull Request"
  fi
fi

if [ "$dotnet_tool_manifest_changes" = true ]; then
  run_timed "restore de ferramentas .NET" dotnet tool restore
fi

if [ "$dotnet_changes" = false ]; then
  if is_full_tests_requested; then
    run_requested_full_tests
    exit 0
  fi

  echo "==> pre-push: nenhuma validacao .NET necessaria; restore, build e testes .NET foram ignorados"
  exit 0
fi

set +e
dotnet run --file ./scripts/quality/resolve-solutions.cs -- "$repo_root" "$changed_file_records" "$impacted_solutions"
resolver_status="$?"
set -e
if [ "$resolver_status" -ne 0 ]; then
  if [ "$resolver_status" -eq 2 ]; then
    echo "==> pre-push: resolvedor encontrou arquivo .NET sem solution segura; validacoes serao executadas por seguranca"
    mark_conservative_fallback_required
    set +e
    dotnet run --file ./scripts/quality/resolve-solutions.cs -- "$repo_root" "$changed_file_records" "$impacted_solutions"
    resolver_status="$?"
    set -e
  fi

  if [ "$resolver_status" -ne 0 ]; then
    exit "$resolver_status"
  fi
fi

if [ ! -s "$impacted_solutions" ]; then
  if is_full_tests_requested; then
    run_requested_full_tests
    exit 0
  fi

  echo "==> pre-push: nenhuma solution .NET impactada"
  echo "==> pre-push: nenhuma validacao .NET e necessaria"
  exit 0
fi

echo "Solutions impactadas:"
while IFS= read -r solution
do
  solution="$(clean_solution_name "$solution")"
  [ -n "$solution" ] || continue
  echo "- $solution"
done <"$impacted_solutions"

if is_full_tests_requested; then
  run_requested_full_tests
  exit 0
fi

while IFS= read -r solution
do
  solution="$(clean_solution_name "$solution")"
  [ -n "$solution" ] || continue

  solution_path="./$solution"
  run_dotnet_step "restore" "$solution" dotnet restore "$solution_path"
  run_dotnet_step "build" "$solution" dotnet build "$solution_path" --configuration "$CONFIGURATION" --no-restore
  run_dotnet_step "test" "$solution" dotnet test "$solution_path" --configuration "$CONFIGURATION" --no-build --no-restore --filter "$UNIT_TEST_FILTER"
done <"$impacted_solutions"

echo "pre-push: todas as validacoes foram aprovadas"
