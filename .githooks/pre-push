#!/usr/bin/env sh
set -eu

CONFIGURATION="${CONFIGURATION:-Release}"
THRESHOLD="${COVERAGE_THRESHOLD:-80}"

if command -v git >/dev/null 2>&1; then
  repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
else
  repo_root="$(pwd)"
fi

cd "$repo_root"

results_dir="$repo_root/TestResults/pre-push"

echo "==> pre-push: restaurando dependencias"
dotnet restore ./LedgerService.slnx

echo "==> pre-push: executando build ($CONFIGURATION)"
dotnet build ./LedgerService.slnx --configuration "$CONFIGURATION" --no-restore

echo "==> pre-push: executando testes com cobertura"
rm -rf "$results_dir"
mkdir -p "$results_dir"

dotnet test ./LedgerService.slnx \
  --configuration "$CONFIGURATION" \
  --no-build \
  --collect:"XPlat Code Coverage" \
  --settings ./coverlet.runsettings \
  --results-directory "$results_dir"

echo "==> pre-push: consolidando cobertura"
dotnet tool restore >/dev/null

report_dir="$results_dir/coverage-report"
dotnet tool run reportgenerator \
  -reports:"$results_dir/**/coverage.cobertura.xml" \
  -targetdir:"$report_dir" \
  -reporttypes:"JsonSummary;TextSummary" >/dev/null

summary_txt="$report_dir/Summary.txt"
if [ ! -f "$summary_txt" ]; then
  echo "pre-push: Summary.txt nao encontrado em $summary_txt." >&2
  exit 1
fi

coverage="$(awk -F'[:%]' '/^[[:space:]]*Line coverage:/ { gsub(/^[[:space:]]+|[[:space:]]+$/, "", $2); print $2; exit }' "$summary_txt")"
if [ -z "$coverage" ]; then
  echo "pre-push: nao foi possivel ler a cobertura de linhas em $summary_txt." >&2
  exit 1
fi

echo "==> pre-push: cobertura total de linhas: $coverage%"

if ! awk -v coverage="$coverage" -v threshold="$THRESHOLD" 'BEGIN { exit (coverage + 0 >= threshold + 0 ? 0 : 1) }'; then
  echo "pre-push: cobertura abaixo do minimo. Atual=$coverage% Minimo=$THRESHOLD%" >&2
  echo "Corrija os testes ou revise a necessidade da mudanca antes de enviar o push." >&2
  exit 1
fi

echo "==> pre-push: build, testes e cobertura aprovados"
