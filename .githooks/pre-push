#!/usr/bin/env sh
set -eu

CONFIGURATION="${CONFIGURATION:-Release}"
THRESHOLD="${COVERAGE_THRESHOLD:-85}"
PRE_PUSH_COVERAGE="${PRE_PUSH_COVERAGE:-false}"
ZERO_SHA="0000000000000000000000000000000000000000"

if command -v git >/dev/null 2>&1; then
  repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
else
  repo_root="$(pwd)"
fi

cd "$repo_root"

results_dir="$repo_root/TestResults/pre-push"

if command -v mktemp >/dev/null 2>&1; then
  changed_files="$(mktemp "${TMPDIR:-/tmp}/pre-push-changed.XXXXXX")"
else
  changed_files="${TMPDIR:-/tmp}/pre-push-changed.$$"
  : >"$changed_files"
fi

trap 'rm -f "$changed_files"' EXIT

is_impacting_path() {
  case "$1" in
    src/*|tests/*|.github/workflows/*|.githooks/*|scripts/*|tools/*|loadtests/k6/lib/*|loadtests/k6/scenarios/*)
      return 0
      ;;
    *.cs|*.csproj|*.sln|*.slnx|*.props|*.targets|*.runsettings|*.editorconfig|*.globalconfig|*.ruleset)
      return 0
      ;;
    *.json|*.yml|*.yaml)
      return 0
      ;;
    Dockerfile|*/Dockerfile|compose.yaml|compose.*.yaml|global.json|NuGet.config|Directory.Build.props|Directory.Build.targets|Directory.Packages.props|dotnet-tools.json|coverlet.runsettings|test.sh|test.ps1)
      return 0
      ;;
  esac

  return 1
}

append_changed_files_from_ref_range() {
  base_ref="$1"
  head_ref="$2"

  git diff --name-only "$base_ref" "$head_ref" >>"$changed_files"
}

append_changed_files_from_base_ref() {
  base_ref="$1"
  head_ref="$2"

  if ! git rev-parse --verify "$base_ref^{commit}" >/dev/null 2>&1; then
    return 1
  fi

  merge_base="$(git merge-base "$head_ref" "$base_ref" 2>/dev/null || true)"
  if [ -z "$merge_base" ]; then
    return 1
  fi

  git diff --name-only "$merge_base" "$head_ref" >>"$changed_files"
}

is_valid_base_ref() {
  base_ref="$1"
  head_ref="$2"

  base_commit="$(git rev-parse --verify "$base_ref^{commit}" 2>/dev/null || true)"
  [ -n "$base_commit" ] || return 1

  head_commit="$(git rev-parse --verify "$head_ref^{commit}" 2>/dev/null || true)"
  [ -n "$head_commit" ] || return 1

  merge_base="$(git merge-base "$head_commit" "$base_commit" 2>/dev/null || true)"
  [ -n "$merge_base" ] || return 1
  [ "$merge_base" != "$head_commit" ] || return 1

  return 0
}

resolve_safe_base_ref() {
  head_ref="$1"
  local_ref="${2:-}"
  resolved_base_ref=""
  branch_name=""

  case "$local_ref" in
    refs/heads/*)
      branch_name="${local_ref#refs/heads/}"
      ;;
  esac

  if [ -n "$branch_name" ]; then
    upstream_ref="$(git rev-parse --abbrev-ref --symbolic-full-name "$branch_name@{u}" 2>/dev/null || true)"
  else
    upstream_ref="$(git rev-parse --abbrev-ref --symbolic-full-name "@{u}" 2>/dev/null || true)"
  fi

  if [ -n "$upstream_ref" ] && is_valid_base_ref "$upstream_ref" "$head_ref"; then
    resolved_base_ref="$upstream_ref"
    return 0
  fi

  if [ -n "$branch_name" ]; then
    configured_remote="$(git config "branch.$branch_name.remote" 2>/dev/null || true)"
    configured_merge="$(git config "branch.$branch_name.merge" 2>/dev/null || true)"

    if [ -n "$configured_remote" ] && [ -n "$configured_merge" ]; then
      case "$configured_merge" in
        refs/heads/*)
          if [ "$configured_remote" = "." ]; then
            configured_base="$configured_merge"
          else
            configured_base="$configured_remote/${configured_merge#refs/heads/}"
          fi

          if is_valid_base_ref "$configured_base" "$head_ref"; then
            resolved_base_ref="$configured_base"
            return 0
          fi
          ;;
      esac
    fi
  fi

  remote_refs="$(git for-each-ref --format='%(refname)' refs/remotes 2>/dev/null || true)"
  while IFS= read -r remote_ref
  do
    [ -n "$remote_ref" ] || continue

    case "$remote_ref" in
      */HEAD)
        remote_head_ref="$(git symbolic-ref --short "$remote_ref" 2>/dev/null || true)"
        if [ -n "$remote_head_ref" ] && is_valid_base_ref "$remote_head_ref" "$head_ref"; then
          resolved_base_ref="$remote_head_ref"
          return 0
        fi
        ;;
    esac
  done <<EOF
$remote_refs
EOF

  head_commit="$(git rev-parse --verify "$head_ref^{commit}" 2>/dev/null || true)"
  [ -n "$head_commit" ] || return 1

  best_base_ref=""
  best_base_time="-1"
  remote_short_refs="$(git for-each-ref --format='%(refname:short)' refs/remotes 2>/dev/null || true)"
  while IFS= read -r candidate_ref
  do
    [ -n "$candidate_ref" ] || continue

    case "$candidate_ref" in
      */HEAD)
        continue
        ;;
    esac

    candidate_commit="$(git rev-parse --verify "$candidate_ref^{commit}" 2>/dev/null || true)"
    [ -n "$candidate_commit" ] || continue

    candidate_merge_base="$(git merge-base "$head_commit" "$candidate_commit" 2>/dev/null || true)"
    [ -n "$candidate_merge_base" ] || continue
    [ "$candidate_merge_base" != "$head_commit" ] || continue

    candidate_base_time="$(git show -s --format=%ct "$candidate_merge_base" 2>/dev/null || echo 0)"
    if [ "$candidate_base_time" -gt "$best_base_time" ]; then
      best_base_time="$candidate_base_time"
      best_base_ref="$candidate_ref"
    fi
  done <<EOF
$remote_short_refs
EOF

  if [ -n "$best_base_ref" ]; then
    resolved_base_ref="$best_base_ref"
    return 0
  fi

  return 1
}

append_changed_files_from_safe_base() {
  head_ref="$1"
  local_ref="${2:-}"

  echo "==> pre-push: tentando identificar branch de origem/base"
  if resolve_safe_base_ref "$head_ref" "$local_ref"; then
    echo "==> pre-push: base identificada: $resolved_base_ref"
    echo "==> pre-push: range analisado: $resolved_base_ref...$head_ref"
    append_changed_files_from_base_ref "$resolved_base_ref" "$head_ref"
    return 0
  fi

  echo "==> pre-push: nao foi possivel determinar a base com seguranca; executando validacoes"
  return 1
}

diff_is_safe=true
stdin_seen=false

echo "==> pre-push: analisando alteracoes pendentes de push"

while read -r local_ref local_sha remote_ref remote_sha
do
  stdin_seen=true

  if [ "$local_sha" = "$ZERO_SHA" ]; then
    echo "==> pre-push: ref removida detectada; ignorando $remote_ref"
    continue
  fi

  if [ -n "$remote_sha" ] && [ "$remote_sha" != "$ZERO_SHA" ]; then
    echo "==> pre-push: branch remota existente detectada"
    echo "==> pre-push: range analisado: $remote_sha..$local_sha"
    if ! append_changed_files_from_ref_range "$remote_sha" "$local_sha"; then
      diff_is_safe=false
    fi
    continue
  fi

  echo "==> pre-push: branch remota ainda nao existe"
  if ! append_changed_files_from_safe_base "$local_sha" "$local_ref"; then
    diff_is_safe=false
  fi
done

if [ "$stdin_seen" = false ]; then
  if ! append_changed_files_from_safe_base "HEAD" ""; then
    diff_is_safe=false
  fi
fi

if [ "$diff_is_safe" = false ]; then
  echo "==> pre-push: validacoes serao executadas por seguranca"
else
  impacting_file=""
  while IFS= read -r changed_file
  do
    [ -z "$changed_file" ] && continue

    if is_impacting_path "$changed_file"; then
      impacting_file="$changed_file"
      break
    fi
  done <"$changed_files"

  if [ -z "$impacting_file" ]; then
    echo "==> pre-push: nenhuma alteracao impactante detectada; pulando build, testes e cobertura"
    exit 0
  fi

  echo "==> pre-push: alteracao impactante detectada em $impacting_file"
fi

echo "==> pre-push: restaurando dependencias"
dotnet restore ./LedgerService.slnx

echo "==> pre-push: executando build ($CONFIGURATION)"
dotnet build ./LedgerService.slnx --configuration "$CONFIGURATION" --no-restore

case "$PRE_PUSH_COVERAGE" in
  true|TRUE|1|yes|YES)
    coverage_enabled=true
    ;;
  *)
    coverage_enabled=false
    ;;
esac

if [ "$coverage_enabled" != true ]; then
  echo "==> pre-push: executando testes rapidos sem cobertura"
  dotnet test ./LedgerService.slnx \
    --configuration "$CONFIGURATION" \
    --no-build \
    --no-restore

  echo "==> pre-push: build e testes rapidos aprovados"
  echo "==> pre-push: para executar cobertura neste hook, use PRE_PUSH_COVERAGE=true"
  exit 0
fi

echo "==> pre-push: executando testes com cobertura"
rm -rf "$results_dir"
mkdir -p "$results_dir"

dotnet test ./LedgerService.slnx \
  --configuration "$CONFIGURATION" \
  --no-build \
  --no-restore \
  --collect:"XPlat Code Coverage" \
  --settings ./coverlet.runsettings \
  --results-directory "$results_dir"

echo "==> pre-push: consolidando cobertura"
dotnet tool restore >/dev/null

report_dir="$results_dir/coverage-report"
dotnet tool run reportgenerator \
  -reports:"$results_dir/**/coverage.cobertura.xml" \
  -targetdir:"$report_dir" \
  -reporttypes:"JsonSummary;TextSummary" >/dev/null

summary_txt="$report_dir/Summary.txt"
if [ ! -f "$summary_txt" ]; then
  echo "pre-push: Summary.txt nao encontrado em $summary_txt." >&2
  exit 1
fi

coverage="$(awk -F'[:%]' '/^[[:space:]]*Line coverage:/ { gsub(/^[[:space:]]+|[[:space:]]+$/, "", $2); print $2; exit }' "$summary_txt")"
if [ -z "$coverage" ]; then
  echo "pre-push: nao foi possivel ler a cobertura de linhas em $summary_txt." >&2
  exit 1
fi

echo "==> pre-push: cobertura total de linhas: $coverage%"

if ! awk -v coverage="$coverage" -v threshold="$THRESHOLD" 'BEGIN { exit (coverage + 0 >= threshold + 0 ? 0 : 1) }'; then
  echo "pre-push: cobertura abaixo do minimo. Atual=$coverage% Minimo=$THRESHOLD%" >&2
  echo "Corrija os testes ou revise a necessidade da mudanca antes de enviar o push." >&2
  exit 1
fi

assert_assembly_coverage() {
  assembly_name="$1"

  assembly_coverage="$(awk -v assembly="$assembly_name" '$1 == assembly { gsub(/%/, "", $NF); print $NF; exit }' "$summary_txt")"
  if [ -z "$assembly_coverage" ]; then
    echo "pre-push: nao foi possivel encontrar a cobertura de $assembly_name em $summary_txt." >&2
    exit 1
  fi

  echo "==> pre-push: cobertura de linhas de $assembly_name: $assembly_coverage%"

  if ! awk -v coverage="$assembly_coverage" -v threshold="$THRESHOLD" 'BEGIN { exit (coverage + 0 >= threshold + 0 ? 0 : 1) }'; then
    echo "pre-push: cobertura de $assembly_name abaixo do minimo. Atual=$assembly_coverage% Minimo=$THRESHOLD%" >&2
    echo "Corrija os testes ou revise a necessidade da mudanca antes de enviar o push." >&2
    exit 1
  fi
}

assert_assembly_coverage "LedgerService.Worker"
assert_assembly_coverage "BalanceService.Worker"

echo "==> pre-push: build, testes e cobertura aprovados"
