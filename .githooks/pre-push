#!/usr/bin/env sh
set -eu

CONFIGURATION="${CONFIGURATION:-Release}"
COVERAGE_THRESHOLD="${COVERAGE_THRESHOLD:-85}"
FULL_TESTS="${FULL_TESTS:-false}"
ZERO_SHA="0000000000000000000000000000000000000000"
UNIT_TEST_FILTER="${UNIT_TEST_FILTER:-Category!=Integration&Category!=Container&Category!=Contract}"
DOTNET_FORMAT_FILE_LIMIT="${DOTNET_FORMAT_FILE_LIMIT:-30}"

if command -v git >/dev/null 2>&1; then
  repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
else
  repo_root="$(pwd)"
fi

cd "$repo_root"

run_timed() {
  step_name="$1"
  shift

  start_time="$(date +%s)"
  echo "==> pre-push: iniciando $step_name"

  set +e
  "$@"
  status="$?"
  set -e

  end_time="$(date +%s)"
  duration="$((end_time - start_time))"

  if [ "$status" -ne 0 ]; then
    echo "==> pre-push: $step_name falhou em ${duration}s"
    exit "$status"
  fi

  echo "==> pre-push: $step_name finalizado em ${duration}s"
}

run_dotnet_format_changed_files() {
  solution_path="$1"
  format_files_path="$2"

  xargs -n 100 dotnet format whitespace "$solution_path" \
    --verify-no-changes \
    --no-restore \
    --verbosity minimal \
    --include <"$format_files_path"
}

count_dotnet_format_files() {
  wc -l <"$1" | tr -d ' '
}

run_full_tests() {
  if ! command -v bash >/dev/null 2>&1; then
    echo "==> pre-push: FULL_TESTS=true exige bash para executar ./test.sh" >&2
    exit 1
  fi

  bash ./test.sh "$CONFIGURATION" "$COVERAGE_THRESHOLD"
}

is_full_tests_requested() {
  case "$FULL_TESTS" in
    true|TRUE|1|yes|YES)
      return 0
      ;;
  esac

  return 1
}

run_requested_full_tests() {
  echo "==> pre-push: FULL_TESTS=true; executando validacao completa oficial com cobertura"
  run_timed "testes completos com cobertura" run_full_tests
  echo "==> pre-push: validacao completa aprovada"
}

if command -v mktemp >/dev/null 2>&1; then
  changed_files="$(mktemp "${TMPDIR:-/tmp}/pre-push-changed.XXXXXX")"
  audit_dotnet_format_files="$(mktemp "${TMPDIR:-/tmp}/pre-push-audit-format.XXXXXX")"
  balance_dotnet_format_files="$(mktemp "${TMPDIR:-/tmp}/pre-push-balance-format.XXXXXX")"
  identity_dotnet_format_files="$(mktemp "${TMPDIR:-/tmp}/pre-push-identity-format.XXXXXX")"
  ledger_dotnet_format_files="$(mktemp "${TMPDIR:-/tmp}/pre-push-ledger-format.XXXXXX")"
  payment_dotnet_format_files="$(mktemp "${TMPDIR:-/tmp}/pre-push-payment-format.XXXXXX")"
  transfer_dotnet_format_files="$(mktemp "${TMPDIR:-/tmp}/pre-push-transfer-format.XXXXXX")"
  shared_dotnet_format_files="$(mktemp "${TMPDIR:-/tmp}/pre-push-shared-format.XXXXXX")"
  aggregate_dotnet_format_files="$(mktemp "${TMPDIR:-/tmp}/pre-push-aggregate-format.XXXXXX")"
else
  changed_files="${TMPDIR:-/tmp}/pre-push-changed.$$"
  audit_dotnet_format_files="${TMPDIR:-/tmp}/pre-push-audit-format.$$"
  balance_dotnet_format_files="${TMPDIR:-/tmp}/pre-push-balance-format.$$"
  identity_dotnet_format_files="${TMPDIR:-/tmp}/pre-push-identity-format.$$"
  ledger_dotnet_format_files="${TMPDIR:-/tmp}/pre-push-ledger-format.$$"
  payment_dotnet_format_files="${TMPDIR:-/tmp}/pre-push-payment-format.$$"
  transfer_dotnet_format_files="${TMPDIR:-/tmp}/pre-push-transfer-format.$$"
  shared_dotnet_format_files="${TMPDIR:-/tmp}/pre-push-shared-format.$$"
  aggregate_dotnet_format_files="${TMPDIR:-/tmp}/pre-push-aggregate-format.$$"
  : >"$changed_files"
  : >"$audit_dotnet_format_files"
  : >"$balance_dotnet_format_files"
  : >"$identity_dotnet_format_files"
  : >"$ledger_dotnet_format_files"
  : >"$payment_dotnet_format_files"
  : >"$transfer_dotnet_format_files"
  : >"$shared_dotnet_format_files"
  : >"$aggregate_dotnet_format_files"
fi

trap 'rm -f "$changed_files" "$audit_dotnet_format_files" "$balance_dotnet_format_files" "$identity_dotnet_format_files" "$ledger_dotnet_format_files" "$payment_dotnet_format_files" "$transfer_dotnet_format_files" "$shared_dotnet_format_files" "$aggregate_dotnet_format_files"' EXIT

