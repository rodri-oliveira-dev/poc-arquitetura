    infra/terraform/*.tf|infra/terraform/*.tfvars|infra/terraform/**/*.tf|infra/terraform/**/*.tfvars|*.tf|*.tfvars)
      return 0
      ;;
  esac

  return 1
}

append_changed_files_from_ref_range() {
  base_ref="$1"
  head_ref="$2"

  git diff --name-only "$base_ref" "$head_ref" >>"$changed_files"
}

append_changed_files_from_base_ref() {
  base_ref="$1"
  head_ref="$2"

  if ! git rev-parse --verify "$base_ref^{commit}" >/dev/null 2>&1; then
    return 1
  fi

  merge_base="$(git merge-base "$head_ref" "$base_ref" 2>/dev/null || true)"
  if [ -z "$merge_base" ]; then
    return 1
  fi

  git diff --name-only "$merge_base" "$head_ref" >>"$changed_files"
}

is_valid_base_ref() {
  base_ref="$1"
  head_ref="$2"

  base_commit="$(git rev-parse --verify "$base_ref^{commit}" 2>/dev/null || true)"
  [ -n "$base_commit" ] || return 1

  head_commit="$(git rev-parse --verify "$head_ref^{commit}" 2>/dev/null || true)"
  [ -n "$head_commit" ] || return 1

  merge_base="$(git merge-base "$head_commit" "$base_commit" 2>/dev/null || true)"
  [ -n "$merge_base" ] || return 1
  [ "$merge_base" != "$head_commit" ] || return 1

  return 0
}

resolve_safe_base_ref() {
  head_ref="$1"
  local_ref="${2:-}"
  resolved_base_ref=""
  branch_name=""

  case "$local_ref" in
    refs/heads/*)
      branch_name="${local_ref#refs/heads/}"
      ;;
  esac

  if [ -n "$branch_name" ]; then
    upstream_ref="$(git rev-parse --abbrev-ref --symbolic-full-name "$branch_name@{u}" 2>/dev/null || true)"
  else
    upstream_ref="$(git rev-parse --abbrev-ref --symbolic-full-name "@{u}" 2>/dev/null || true)"
  fi

  if [ -n "$upstream_ref" ] && is_valid_base_ref "$upstream_ref" "$head_ref"; then
    resolved_base_ref="$upstream_ref"
    return 0
  fi

  if [ -n "$branch_name" ]; then
    configured_remote="$(git config "branch.$branch_name.remote" 2>/dev/null || true)"
    configured_merge="$(git config "branch.$branch_name.merge" 2>/dev/null || true)"

    if [ -n "$configured_remote" ] && [ -n "$configured_merge" ]; then
      case "$configured_merge" in
        refs/heads/*)
          if [ "$configured_remote" = "." ]; then
            configured_base="$configured_merge"
          else
            configured_base="$configured_remote/${configured_merge#refs/heads/}"
          fi

          if is_valid_base_ref "$configured_base" "$head_ref"; then
            resolved_base_ref="$configured_base"
            return 0
          fi
          ;;
      esac
    fi
  fi

  remote_refs="$(git for-each-ref --format='%(refname)' refs/remotes 2>/dev/null || true)"
  while IFS= read -r remote_ref
  do
    [ -n "$remote_ref" ] || continue

    case "$remote_ref" in
      */HEAD)
        remote_head_ref="$(git symbolic-ref --short "$remote_ref" 2>/dev/null || true)"
        if [ -n "$remote_head_ref" ] && is_valid_base_ref "$remote_head_ref" "$head_ref"; then
          resolved_base_ref="$remote_head_ref"
          return 0
        fi
        ;;
    esac
  done <<EOF
$remote_refs
EOF

  head_commit="$(git rev-parse --verify "$head_ref^{commit}" 2>/dev/null || true)"
  [ -n "$head_commit" ] || return 1

  best_base_ref=""
  best_base_time="-1"
  remote_short_refs="$(git for-each-ref --format='%(refname:short)' refs/remotes 2>/dev/null || true)"
  while IFS= read -r candidate_ref
  do
    [ -n "$candidate_ref" ] || continue

    case "$candidate_ref" in
      */HEAD)
        continue
        ;;
    esac

    candidate_commit="$(git rev-parse --verify "$candidate_ref^{commit}" 2>/dev/null || true)"
    [ -n "$candidate_commit" ] || continue

    candidate_merge_base="$(git merge-base "$head_commit" "$candidate_commit" 2>/dev/null || true)"
    [ -n "$candidate_merge_base" ] || continue
    [ "$candidate_merge_base" != "$head_commit" ] || continue

    candidate_base_time="$(git show -s --format=%ct "$candidate_merge_base" 2>/dev/null || echo 0)"
    if [ "$candidate_base_time" -gt "$best_base_time" ]; then
      best_base_time="$candidate_base_time"
      best_base_ref="$candidate_ref"
    fi
  done <<EOF
$remote_short_refs
EOF

  if [ -n "$best_base_ref" ]; then
    resolved_base_ref="$best_base_ref"
    return 0
  fi

  return 1
}

append_changed_files_from_safe_base() {
  head_ref="$1"
  local_ref="${2:-}"

  echo "==> pre-push: tentando identificar branch de origem/base"
  if resolve_safe_base_ref "$head_ref" "$local_ref"; then
    echo "==> pre-push: base identificada: $resolved_base_ref"
    echo "==> pre-push: range analisado: $resolved_base_ref...$head_ref"
    append_changed_files_from_base_ref "$resolved_base_ref" "$head_ref"
    return 0
  fi

  echo "==> pre-push: nao foi possivel determinar a base com seguranca; executando validacoes"
  return 1
}

diff_is_safe=true
stdin_seen=false

echo "==> pre-push: analisando alteracoes pendentes de push"

while read -r local_ref local_sha remote_ref remote_sha
do
  [ -n "$local_ref" ] || continue
  [ -n "$local_sha" ] || continue
  [ -n "$remote_ref" ] || continue
  [ -n "$remote_sha" ] || continue

  stdin_seen=true

  if [ "$local_sha" = "$ZERO_SHA" ]; then
    echo "==> pre-push: ref removida detectada; ignorando $remote_ref"
    continue
  fi

  if [ -n "$remote_sha" ] && [ "$remote_sha" != "$ZERO_SHA" ]; then
    echo "==> pre-push: branch remota existente detectada"
    echo "==> pre-push: range analisado: $remote_sha..$local_sha"
    if ! append_changed_files_from_ref_range "$remote_sha" "$local_sha"; then
      diff_is_safe=false
    fi
    continue
  fi

  echo "==> pre-push: branch remota ainda nao existe"
  if ! append_changed_files_from_safe_base "$local_sha" "$local_ref"; then
    diff_is_safe=false
  fi
done

if [ "$stdin_seen" = false ]; then
  if ! append_changed_files_from_safe_base "HEAD" ""; then
    diff_is_safe=false
  fi
fi

dotnet_changes=false
audit_changes=false
balance_changes=false
identity_changes=false
ledger_changes=false
payment_changes=false
transfer_changes=false
shared_changes=false
aggregate_changes=false
terraform_changes=false
dockerfile_changes=false
compose_changes=false
container_changes=false
global_dotnet_changes=false
analyzer_config_changes=false
dotnet_tool_manifest_changes=false
quick_tests_required=false
dotnet_format_check=true

if [ "$diff_is_safe" = false ]; then
  echo "==> pre-push: validacoes serao executadas por seguranca"
  dotnet_changes=true
  audit_changes=false
  balance_changes=false
  identity_changes=false
  ledger_changes=false
  payment_changes=false
  transfer_changes=false
  shared_changes=true
  aggregate_changes=true
  terraform_changes=true
  dockerfile_changes=true
  compose_changes=true
  container_changes=true
  quick_tests_required=true
  dotnet_format_check=false
else
  while IFS= read -r changed_file
  do
    [ -n "$changed_file" ] || continue

    if is_global_dotnet_path "$changed_file"; then
      dotnet_changes=true
      global_dotnet_changes=true
      shared_changes=true
      aggregate_changes=true
      echo "==> pre-push: alteracao .NET global detectada em $changed_file"
    fi

    if is_analyzer_config_path "$changed_file"; then
      dotnet_changes=true
      analyzer_config_changes=true
      shared_changes=true
      aggregate_changes=true
      echo "==> pre-push: alteracao de configuracao de analyzer detectada em $changed_file"
    fi

    if is_dotnet_tool_manifest_path "$changed_file"; then
      dotnet_tool_manifest_changes=true
      echo "==> pre-push: alteracao de manifesto de ferramenta .NET detectada em $changed_file"
    fi

    if is_pre_push_hook_path "$changed_file"; then
      dotnet_changes=true
      global_dotnet_changes=true
      shared_changes=true
      aggregate_changes=true
      echo "==> pre-push: alteracao no pre-push detectada em $changed_file"
    fi

    if is_event_contracts_path "$changed_file"; then
      dotnet_changes=true
      ledger_changes=true
      balance_changes=true
      quick_tests_required=true
      echo "==> pre-push: alteracao em contratos de evento detectada em $changed_file"
    fi

    if is_shared_path "$changed_file"; then
      dotnet_changes=true
      shared_changes=true
      quick_tests_required=true
      echo "==> pre-push: alteracao Shared detectada em $changed_file"
      append_dotnet_format_file "$changed_file" "$shared_dotnet_format_files"
    fi

    if is_audit_path "$changed_file"; then
      dotnet_changes=true
      audit_changes=true
      quick_tests_required=true
      echo "==> pre-push: alteracao Audit detectada em $changed_file"
      append_dotnet_format_file "$changed_file" "$audit_dotnet_format_files"
    fi

    if is_balance_path "$changed_file"; then
      dotnet_changes=true
      balance_changes=true
      quick_tests_required=true
      echo "==> pre-push: alteracao Balance detectada em $changed_file"
      append_dotnet_format_file "$changed_file" "$balance_dotnet_format_files"
    fi

    if is_identity_path "$changed_file"; then
      dotnet_changes=true
      identity_changes=true
      quick_tests_required=true
      echo "==> pre-push: alteracao Identity detectada em $changed_file"
      append_dotnet_format_file "$changed_file" "$identity_dotnet_format_files"
    fi

    if is_ledger_path "$changed_file"; then
      dotnet_changes=true
      ledger_changes=true
      quick_tests_required=true
      echo "==> pre-push: alteracao Ledger detectada em $changed_file"
      append_dotnet_format_file "$changed_file" "$ledger_dotnet_format_files"
    fi

    if is_payment_path "$changed_file"; then
      dotnet_changes=true
      payment_changes=true
      quick_tests_required=true
      echo "==> pre-push: alteracao Payment detectada em $changed_file"
      append_dotnet_format_file "$changed_file" "$payment_dotnet_format_files"
    fi

    if is_transfer_path "$changed_file"; then
      dotnet_changes=true
      transfer_changes=true
      quick_tests_required=true
      echo "==> pre-push: alteracao Transfer detectada em $changed_file"
      append_dotnet_format_file "$changed_file" "$transfer_dotnet_format_files"
    fi

    if is_aggregate_path "$changed_file"; then
      dotnet_changes=true
      aggregate_changes=true
      quick_tests_required=true
      echo "==> pre-push: alteracao agregadora detectada em $changed_file"
      append_dotnet_format_file "$changed_file" "$aggregate_dotnet_format_files"
    fi

    if is_terraform_impacting_path "$changed_file"; then
      terraform_changes=true
      echo "==> pre-push: alteracao Terraform detectada em $changed_file"
    fi

    if is_dockerfile_path "$changed_file"; then
      dockerfile_changes=true
      container_changes=true
      echo "==> pre-push: alteracao de Dockerfile detectada em $changed_file"
    fi

    if is_compose_path "$changed_file"; then
      compose_changes=true
      container_changes=true
      echo "==> pre-push: alteracao Docker Compose detectada em $changed_file"
    fi

    if is_container_baseline_validation_path "$changed_file"; then
      dockerfile_changes=true
      container_changes=true
      echo "==> pre-push: alteracao em validacao de container baseline detectada em $changed_file"
    fi

    if is_compose_validation_path "$changed_file"; then
      compose_changes=true
      container_changes=true
      echo "==> pre-push: alteracao em validacao Docker Compose detectada em $changed_file"
    fi
  done <"$changed_files"

  if [ "$global_dotnet_changes" = true ]; then
    audit_changes=false
    balance_changes=false
    identity_changes=false
    ledger_changes=false
    payment_changes=false
    transfer_changes=false
    shared_changes=true
    aggregate_changes=true
    quick_tests_required=true
