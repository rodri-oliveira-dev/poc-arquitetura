## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools. If you are
## developing with Visual Studio, the VS .gitignore
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
## has more thorough IDE-specific entries.
##
## Get latest from https://github.com/github/gitignore/blob/main/Dotnet.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Dd]ist/
[Ll]og/
[Ll]ogs/

# Node tooling
node_modules/


# Visual Studio / VS Code
.vs/

# Test artifacts
TestResults/
StrykerOutput/
*.user
*.suo
*.userosscache
*.sln.docstates

# Rider/IntelliJ
.idea/

# OS / tooling
Thumbs.db
Desktop.ini

# Local environment overrides
.env
.env.*
!.env.example
!.env.local.example
.env.local
appsettings.Local.json
**/appsettings.Local.json

# Local certificates and private keys
*.key
*.pem
*.pfx
*.p12
secrets/
infra/nginx/certs/*
!infra/nginx/certs/.gitignore
!infra/nginx/certs/README.md

# Testes
**/TestResults/

# Coverage
coverage/
coverage.*

# Auth.Api (POC) - chave RSA persistida localmente (NÃO versionar)
# (o caminho real do projeto é src/Auth.Api)
src/Auth.Api/data/

# Diretório local opcional usado pelo compose para persistir a chave (não versionar)
data/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg
.nuget/
# NuGet Symbol Packages
*.snupkg

# Others
~$*
*~
CodeCoverage/

# MSBuild Binary and Structured Log
*.binlog

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# DotNet tools restore
.dotnet/
.dotnet-home/

# k6 / load tests
.env.k6.auto
artifacts/k6/
artifacts/k6/*
zap-reports

# Terraform
**/.terraform/
infra/terraform/modules/**/.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
!infra/terraform/environments/dev/validation.tfvars
*.tfplan
tfplan

# Google Cloud CLI / credenciais locais
application_default_credentials.json
service-account-key.json
