{
  "dotnet.defaultSolution": "LedgerService.slnx",
  "dotnet.server.useOmnisharp": false,
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },
  "files.associations": {
    "*.slnx": "xml"
  },
  "files.exclude": {
    "**/bin": true,
    "**/obj": true,
    "**/.vs": true,
    "**/.git": true,
    "**/TestResults": true,
    "**/artifacts/test-results": true,
    "**/artifacts/k6": true,
    "**/coverage-report": true
  },
  "search.exclude": {
    "**/bin": true,
    "**/obj": true,
    "**/.vs": true,
    "**/.git": true,
    "**/TestResults": true,
    "**/artifacts/test-results": true,
    "**/artifacts/k6": true,
    "**/coverage-report": true
  },
  "files.watcherExclude": {
    "**/bin/**": true,
    "**/obj/**": true,
    "**/.vs/**": true,
    "**/TestResults/**": true,
    "**/artifacts/test-results/**": true,
    "**/artifacts/k6/**": true,
    "**/coverage-report/**": true
  },
  "search.useIgnoreFiles": true,
  "search.useGlobalIgnoreFiles": true,
  "markdown.preview.mermaid": true,
  "markdown.preview.experimental.useMermaid": true
}
