{
  "dotnet.defaultSolution": "LedgerService.slnx",
  "dotnet.server.useOmnisharp": false,
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },
  "files.associations": {
    "*.slnx": "xml"
  },
  "terminal.integrated.env.windows": {
    "Path": "C:\\Program Files\\nodejs;C:\\Users\\rodrigooliveira\\AppData\\Roaming\\npm;C:\\Python314;C:\\Python314\\Scripts;${env:Path}"
  },
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "args": [
        "-NoLogo",
        "-ExecutionPolicy",
        "Bypass"
      ]
    }
  },
  "python.defaultInterpreterPath": "C:\\Python314\\python.exe",
  "files.exclude": {
    "**/bin": true,
    "**/obj": true,
    "**/.vs": true,
    "**/.git": true,
    "**/.dotnet": true,
    "**/.dotnet-home": true,
    "**/.nuget": true,
    "**/TestResults": true,
    "**/artifacts/test-results": true,
    "**/artifacts/k6": true,
    "**/coverage": true,
    "**/coverage-report": true,
    "**/StrykerOutput": true
  },
  "search.exclude": {
    "**/bin": true,
    "**/obj": true,
    "**/.vs": true,
    "**/.git": true,
    "**/.dotnet": true,
    "**/.dotnet-home": true,
    "**/.nuget": true,
    "**/TestResults": true,
    "**/artifacts/test-results": true,
    "**/artifacts/k6": true,
    "**/coverage": true,
    "**/coverage-report": true,
    "**/StrykerOutput": true
  },
  "files.watcherExclude": {
    "**/bin/**": true,
    "**/obj/**": true,
    "**/.vs/**": true,
    "**/.dotnet/**": true,
    "**/.dotnet-home/**": true,
    "**/.nuget/**": true,
    "**/TestResults/**": true,
    "**/artifacts/test-results/**": true,
    "**/artifacts/k6/**": true,
    "**/coverage/**": true,
    "**/coverage-report/**": true,
    "**/StrykerOutput/**": true
  },
  "search.useIgnoreFiles": true,
  "search.useGlobalIgnoreFiles": true,
  "markdown.preview.mermaid": true,
  "markdown.preview.experimental.useMermaid": true
}
