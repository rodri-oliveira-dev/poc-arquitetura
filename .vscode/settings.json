{
  // ---------------------------------------------------------------------------
  // Performance / qualidade de vida
  // ---------------------------------------------------------------------------
  "files.exclude": {
    "**/bin": true,
    "**/obj": true,
    "**/.vs": true
  },
  "search.exclude": {
    "**/bin": true,
    "**/obj": true,
    "**/.vs": true
  },

  // ---------------------------------------------------------------------------
  // .NET / C# (recomendado para .NET 10)
  // ---------------------------------------------------------------------------
  "dotnet.defaultSolution": "LedgerService.slnx",

  // O C# Dev Kit normalmente usa o servidor Roslyn (não OmniSharp)
  "dotnet.server.useOmnisharp": false,

  // ---------------------------------------------------------------------------
  // Editor
  // ---------------------------------------------------------------------------
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },

  "files.associations": {
    "*.slnx": "xml"
  },

  // ---------------------------------------------------------------------------
  // Markdown / Mermaid
  // ---------------------------------------------------------------------------
  "markdown.preview.mermaid": true,
  "markdown.preview.experimental.useMermaid": true
}
