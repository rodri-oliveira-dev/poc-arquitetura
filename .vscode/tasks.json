        "${workspaceFolder}/src/BalanceService.Worker/BalanceService.Worker.csproj",
        "--configuration",
        "Debug"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "local stack: start",
      "type": "shell",
      "command": "./scripts/start-local-stack.sh",
      "windows": {
        "command": "./scripts/start-local-stack.ps1",
        "options": {
          "shell": {
            "executable": "powershell.exe",
            "args": [
              "-NoLogo",
              "-NoProfile",
              "-ExecutionPolicy",
              "Bypass",
              "-Command"
            ]
          }
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "local stack: start with observability",
      "type": "shell",
