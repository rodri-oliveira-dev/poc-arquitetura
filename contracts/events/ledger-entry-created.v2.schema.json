{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://poc-arquitetura.local/contracts/events/ledger-entry-created.v2.schema.json",
  "title": "LedgerEntryCreated.v2",
  "description": "Payload logico do fato financeiro publicado pelo LedgerService para atualizacao de saldo no BalanceService, com moeda explicita.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "amount",
    "currency",
    "createdAt",
    "merchantId",
    "occurredAt",
    "correlationId"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^lan_[0-9a-f]{8}$",
      "description": "Identificador logico estavel do lancamento."
    },
    "type": {
      "type": "string",
      "enum": [
        "CREDIT",
        "DEBIT"
      ],
      "description": "Tipo financeiro atual do lancamento."
    },
    "amount": {
      "type": "string",
      "pattern": "^-?[0-9]+\\.[0-9]{2}$",
      "description": "Valor decimal serializado como string com duas casas."
    },
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$",
      "description": "Moeda ISO 4217 do lancamento. Obrigatoria em v2."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Instante de criacao no LedgerService."
    },
    "merchantId": {
      "type": "string",
      "minLength": 1,
      "description": "Merchant dono do lancamento e da projecao."
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time",
      "description": "Instante do fato financeiro."
    },
    "description": {
      "type": [
        "string",
        "null"
      ],
      "description": "Descricao opcional."
    },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "Correlacao logica do fluxo de origem."
    },
    "externalReference": {
      "type": [
        "string",
        "null"
      ],
      "description": "Referencia externa opcional."
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "const": "CREDIT"
          }
        }
      },
      "then": {
        "properties": {
          "amount": {
            "pattern": "^(?:0\\.(?:0[1-9]|[1-9][0-9])|[1-9][0-9]*\\.[0-9]{2})$"
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "const": "DEBIT"
          }
        }
      },
      "then": {
        "properties": {
          "amount": {
            "pattern": "^-(?:0\\.(?:0[1-9]|[1-9][0-9])|[1-9][0-9]*\\.[0-9]{2})$"
          }
        }
      }
    }
  ]
}
