  audit.auditWorker.auditRecordConsumer -> audit.auditWorker.auditRecordProcessor "Entrega mensagem recebida" "processor"
  audit.auditWorker.auditRecordProcessor -> audit.auditWorker.auditWorkerComposition "Usa servicos de Application/Infrastructure resolvidos por escopo DI" "DI / MediatR"
  audit.auditWorker.auditRecordProcessor -> audit.auditDb "Persiste auditoria por source_event_id idempotente" "EF Core"
