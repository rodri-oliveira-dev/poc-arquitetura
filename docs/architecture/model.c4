  payment.paymentWorker.paymentLedgerWorker -> payment.paymentWorker.paymentLedgerProcessor "Coordena batches de materializacao financeira" "DI"
  payment.paymentWorker.paymentLedgerProcessor -> payment.paymentDb "Faz claim persistido e salva ledgerEntryId/retry/deadletter" "EF Core / SQL"
  payment.paymentWorker.paymentLedgerProcessor -> payment.paymentWorker.ledgerHttpGateway "Chama porta ILedgerEntryGateway" "porta"
