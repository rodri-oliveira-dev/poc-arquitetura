  payment.paymentApi.paymentPersistence -> payment.paymentDb "Persiste Payment, idempotencia e Inbox" "EF Core"
  payment.paymentApi -> payment.paymentDb "Persiste Payment, registros de idempotencia e Inbox de webhooks" "EF Core"
