  payment.paymentWorker.paymentWorkerComposition -> payment.paymentWorker.paymentLedgerWorker "Hospeda materializacao Ledger" "HostedService"
  payment.paymentWorker.paymentInboxWorker -> payment.paymentDb "Faz claim da Inbox, atualiza Inbox e Payment na mesma transacao local" "EF Core / SQL"
