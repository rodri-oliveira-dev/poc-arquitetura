  view paymentLedgerFlow {
    title "Fluxo Payment -> Ledger -> Kafka -> Balance"
    include stripe.stripeApi
    include stripe.stripeWebhooks
    include payment.paymentApi
    include payment.paymentWorker
    include payment.paymentDb
    include payment.paymentInboxWorker
    include payment.paymentWorker.paymentLedgerWorker
    include payment.paymentWorker.paymentLedgerProcessor
    include payment.paymentWorker.ledgerHttpGateway
    include identity.keycloak
    include ledger.ledgerApi
    include ledger.ledgerDb
    include ledger.ledgerWorker
    include ledger.ledgerEstornoProcessor
    include ledger.ledgerOutbox
    include ledger.ledgerKafkaOutboxPublisher
