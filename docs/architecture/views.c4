  view distributedFlow {
    title "Fluxo distribuido principal - Keycloak, Ledger, Outbox, Kafka e Balance"
    include customer
    include identity.keycloak
    include ledger.ledgerApi
    include ledger.ledgerDb
    include ledger.ledgerWorker
    include ledger.ledgerOutbox
    include ledger.ledgerKafkaOutboxPublisher
