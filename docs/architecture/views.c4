    include payment.paymentWorker.paymentLedgerWorker
    include payment.paymentWorker.paymentLedgerProcessor
    include payment.paymentWorker.ledgerHttpGateway
    include payment.paymentApplication
    include payment.paymentDomain
    include payment.paymentInfrastructure
    include payment.paymentDb
    autoLayout LeftRight
  }
}
