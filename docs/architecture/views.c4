  dynamic view auditKafkaIngestionFlow {
    title "Dynamic View - auditoria Kafka opcional"
    description "Estado atual: AuditService.Worker pode consumir AuditRecordRequested.v1, mas Ledger, Balance, Transfer e Payment ainda nao publicam eventos reais de auditoria."

    kafka.auditRecordTopic -> audit.auditWorker.auditRecordConsumer "1. Entrega AuditRecordRequested.v1 quando um producer futuro existir"
    audit.auditWorker.auditRecordConsumer -> audit.auditWorker.auditRecordProcessor "2. Controla retry local e envia mensagem ao processor"
    audit.auditWorker.auditRecordProcessor -> audit.auditApplication "3. Valida contrato canonico e envia CreateAuditRecordCommand"
    audit.auditApplication -> audit.auditDb "4. Persiste functional_audit_records com source_event_id idempotente"
    audit.auditWorker.auditRecordProcessor -> audit.auditWorker.auditDeadLetterPublisher "5. Encaminha JSON invalido, contrato incompativel ou conflito definitivo"
    audit.auditWorker.auditDeadLetterPublisher -> kafka.auditRecordDlq "6. Publica DLQ de aplicacao minimizada antes do commit"

    autoLayout LeftRight
  }
}
