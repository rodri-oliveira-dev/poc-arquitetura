  dynamic view identityRegistrationFlow {
    title "Dynamic View - cadastro de usuario no IdentityService"
    description "Estado atual: cadastro sincronico cria usuario no Keycloak antes do commit local; e-mail e side effect depois do commit, sem Outbox nesta etapa."

    customer -> identityService.identityEndpoints "1. Chama POST /api/v1/users com JWT identity.write"
    identityService.identityEndpoints -> identityService.identityApplication "2. Valida request e cria CreateUserCommand"
    identityService.identityApplication -> identityService.keycloakAdminClient "3. Solicita criacao do usuario no provider"
    identityService.keycloakAdminClient -> identity.keycloak "4. Obtem token admin, cria usuario e define senha"
    identityService.identityApplication -> identityService.identityDomain "5. Gera MerchantId e cria aggregate User"
    identityService.identityApplication -> identityService.identityDbContext "6. Persiste usuario local"
    identityService.identityDbContext -> identityService.identityDb "7. Commit no schema identity"
    identityService.identityDbContext -> identityService.domainEventDispatcher "8. Despacha UserRegisteredDomainEvent apos commit"
    identityService.domainEventDispatcher -> identityService.emailHandlers "9. Executa handler de boas-vindas"
    identityService.emailHandlers -> identityService.welcomeEmailTemplate "10. Renderiza template HTML"
    identityService.emailHandlers -> identityService.emailSenderPort "11. Envia por IEmailSender"
    identityService.emailSenderPort -> email.mailpit "12a. Captura local quando Email:Provider=Mailpit"
    identityService.emailSenderPort -> email.resend "12b. Envia real quando Email:Provider=Resend"
    identityService.identityEndpoints -> customer "13. Retorna 201 com Id, KeycloakUserId, MerchantId, username e email"

    autoLayout LeftRight
  }

  view pubSubLegacyFlow {
    title "Fluxo alternativo/legado - Pub/Sub emulator/GCP"
    include ledger.ledgerWorker
    include ledger.ledgerOutbox
    include ledger.ledgerPubSubOutboxPublisher
