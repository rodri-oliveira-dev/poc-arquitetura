    include identityService.identityInfrastructure
    include identityService.keycloakAdminClient
    include identityService.identityDbContext
    include identityService.domainEventDispatcher
    include identityService.emailHandlers
    include identityService.emailSenderPort
    include identityService.mailpitEmailSender
    include identityService.resendEmailSender
    include identityService.welcomeEmailTemplate
    include identityService.identityDb
    include identity.keycloak
    include email.mailpit
    include email.resend
