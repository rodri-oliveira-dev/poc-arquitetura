// LikeC4 views for poc-arquitetura.

views {
  view systemLandscape {
    title "System Landscape - poc-arquitetura"
    description "Mostra os sistemas e atores ao redor da POC. Use esta view para entender o ecossistema sem detalhes de classes, workers internos ou tabelas."
    include customer
    include edge
    include identity
    include identityService
    include ledger
    include balance
    include transfer
    include payment
    include audit
    include stripe
    include kafka
    include email
    include observability
    autoLayout LeftRight
  }

  view containers {
    title "Container View - APIs, workers, bancos, Kafka e observabilidade"
    description "Mostra executaveis, schemas/boundaries de banco, o broker Kafka e sistemas externos da arquitetura atual. Schemas PostgreSQL representam isolamento logico por bounded context, nao necessariamente instancias fisicas separadas."
    include customer
    include edge.nginx
    include identity.keycloak
    include identityService.identityApi
    include identityService.identityDb
    include ledger.ledgerApi
    include ledger.ledgerWorker
    include ledger.ledgerDb
    include balance.balanceApi
    include balance.balanceWorker
    include balance.balanceDb
    include transfer.transferApi
    include transfer.transferWorker
    include transfer.transferDb
    include payment.paymentApi
    include payment.paymentWorker
    include payment.paymentDb
    include audit.auditApi
    include audit.auditWorker
    include audit.auditDb
    include stripe.stripeApi
    include stripe.stripeWebhooks
    include kafka
    include email.mailpit
    include email.resend
    include observability.collector
    include observability.jaeger
    include observability.prometheus
    include observability.loki
    include observability.alloy
    include observability.alertmanager
    include observability.grafana
    autoLayout LeftRight
  }

  dynamic view ledgerBalanceProjectionFlow {
    title "Dynamic View - lancamento financeiro vira saldo"
    description "Estado atual: LedgerService.Api e dono do fato financeiro; LedgerService.Worker publica a Outbox no Kafka; BalanceService.Worker projeta saldo de forma idempotente."

    customer -> identity.keycloak "1. Obtem JWT com audience ledger-api e scope adequado"
    customer -> ledger.ledgerApi "2. Chama POST /api/v1/lancamentos com Idempotency-Key"
    ledger.ledgerApi -> ledger.ledgerDb "3. Persiste LedgerEntry, idempotencia e Outbox na mesma transacao"
    ledger.ledgerWorker.ledgerOutbox -> ledger.ledgerDb "4. Reclama outbox_messages pendentes"
    ledger.ledgerWorker.ledgerKafkaOutboxPublisher -> kafka.ledgerTopic "5. Publica LedgerEntryCreated.v2"
    balance.balanceWorker.balanceConsumer -> kafka.ledgerTopic "6. Consome evento financeiro do Ledger"
    balance.balanceWorker.balanceReceivedMessageMapper -> balance.balanceWorker.balanceMessageProcessor "7. Mapeia transporte Kafka para ReceivedMessage"
    balance.balanceWorker.balanceMessageProcessor -> balance.balanceDb "8. Atualiza daily_balances e processed_events"
    customer -> balance.balanceApi "9. Consulta saldo projetado"
    balance.balanceApi -> balance.balanceDb "10. Le projecao"

    autoLayout LeftRight
  }

  dynamic view identityRegistrationFlow {
    title "Dynamic View - cadastro de usuario no IdentityService"
    description "Estado atual: cadastro sincronico cria usuario no Keycloak antes do commit local; e-mail e side effect depois do commit, sem Outbox nesta etapa."

    customer -> identityService.identityEndpoints "1. Chama POST /api/v1/users com JWT identity.write"
    identityService.identityEndpoints -> identityService.identityApplication "2. Valida request e cria CreateUserCommand"
    identityService.identityApplication -> identityService.keycloakAdminClient "3. Solicita criacao do usuario no provider"
    identityService.keycloakAdminClient -> identity.keycloak "4. Obtem token admin, cria usuario e define senha"
    identityService.identityApplication -> identityService.identityDomain "5. Gera MerchantId e cria aggregate User"
    identityService.identityApplication -> identityService.identityDbContext "6. Persiste usuario local"
    identityService.identityDbContext -> identityService.identityDb "7. Commit no schema identity"
    identityService.identityDbContext -> identityService.domainEventDispatcher "8. Despacha UserRegisteredDomainEvent apos commit"
    identityService.domainEventDispatcher -> identityService.emailHandlers "9. Executa handler de boas-vindas"
    identityService.emailHandlers -> identityService.welcomeEmailTemplate "10. Renderiza template HTML"
    identityService.emailHandlers -> identityService.emailSenderPort "11. Envia por IEmailSender"
    identityService.emailSenderPort -> email.mailpit "12a. Captura local quando Email:Provider=Mailpit"
    identityService.emailSenderPort -> email.resend "12b. Envia real quando Email:Provider=Resend"
    identityService.identityEndpoints -> customer "13. Retorna 201 com Id, KeycloakUserId, MerchantId, username e email"

    autoLayout LeftRight
  }

  view kafkaFlow {
    title "Kafka - mensageria assincrona documentada"
    description "Mostra onde Kafka e usado no runtime documentado como provider padrao: fluxo financeiro Ledger/Balance, eventos da Saga do TransferService e consumer opcional do AuditService sem producers reais nesta etapa."
    include ledger.ledgerWorker
    include ledger.ledgerKafkaOutboxPublisher
    include ledger.ledgerReprocessamentoConsumer
    include kafka.ledgerTopic
    include kafka.ledgerEstornoTopic
    include kafka.ledgerReprocessamentoTopic
    include kafka.ledgerDlq
    include balance.balanceWorker
    include balance.balanceConsumer
    include balance.balanceDeadLetterPort
    include transfer.transferWorker
    include kafka.transferSagaTopics
    include kafka.transferSagaDlq
    include audit.auditWorker
    include audit.auditRecordConsumer
    include audit.auditDeadLetterPublisher
    include kafka.auditRecordTopic
    include kafka.auditRecordDlq
    autoLayout LeftRight
  }

  view observabilityFlow {
    title "Observabilidade local - traces, metricas, logs, dashboards e alertas"
    include identity.keycloak
