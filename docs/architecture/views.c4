    include balance.balanceApi
    include balance.balanceWorker
    include transfer.transferApi
    include transfer.transferWorker
    include payment.paymentApi
    include payment.paymentWorker
    include audit.auditApi
    include audit.auditWorker
    include observability.collector
    include observability.jaeger
    include observability.prometheus
    include observability.loki
    include observability.alloy
    include observability.alertmanager
    include observability.grafana
    include observability.grafana.dashboards
    autoLayout LeftRight
  }

  view identityServiceComponents of identityService.identityApi {
