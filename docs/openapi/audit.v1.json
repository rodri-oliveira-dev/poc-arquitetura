      "get": {
        "tags": [
          "AuditRecords"
        ],
        "summary": "Consulta um registro de auditoria funcional por id.",
        "description": "Retorna um registro de auditoria funcional sem expor payload bruto sensivel.\n\n<b>Autorizacao</b>: requer policy/scope <c>audit.read</c>. (claim <c>scope</c> do JWT)",
        "operationId": "GetAuditRecordById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Registro de auditoria encontrado.",
