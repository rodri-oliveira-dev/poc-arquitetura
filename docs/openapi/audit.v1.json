{
  "openapi": "3.0.4",
  "info": {
    "title": "Poc Arquitetura Audit API",
    "description": "Bounded context de auditoria funcional",
    "version": "1.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "Servidor relativo do AuditService.Api"
    }
  ],
  "paths": {
    "/api/v1/audit-records": {
      "post": {
        "tags": [
          "AuditRecords"
        ],
        "summary": "Cria um registro de auditoria funcional.",
        "description": "Cria um registro canonico e agnostico de auditoria funcional. O endpoint exige Idempotency-Key em formato UUID.",
        "operationId": "CreateAuditRecord",
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "description": "Chave de idempotencia em formato UUID.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Correlation-Id",
            "in": "header",
            "description": "Correlation id opcional em formato UUID. Se ausente, a API usa correlationId do body ou o valor gerado pelo middleware.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAuditRecordRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAuditRecordRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAuditRecordRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Registro de auditoria criado.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/CreateAuditRecordResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateAuditRecordResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateAuditRecordResponse"
                }
              }
            }
          },
          "400": {
            "description": "Request invalido.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "409": {
            "description": "Conflito de idempotencia.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "422": {
            "description": "Violacao de regra de dominio.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "429": {
            "description": "Limite de requisicoes excedido."
          },
          "500": {
            "description": "Erro interno.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        },
        "security": [ ]
      }
    },
    "/health": {
      "get": {
        "tags": [
          "Operacional"
        ],
        "summary": "Health check simples",
        "description": "Retorna 200 com body 'ok'. Endpoint publico para liveness simples.",
        "operationId": "Health",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [ ]
      }
    },
    "/ready": {
      "get": {
        "tags": [
          "Operacional"
        ],
        "summary": "Readiness check",
        "description": "Valida o estado interno inicial do AuditService. O servico ainda nao possui dependencias externas configuradas.",
        "operationId": "Ready",
        "responses": {
          "200": {
            "description": "OK"
          },
          "503": {
            "description": "Service Unavailable"
          }
        },
        "security": [ ]
      }
    }
  },
