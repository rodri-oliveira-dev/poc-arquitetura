              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/AuditRecordResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuditRecordResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuditRecordResponse"
                }
              }
            }
          },
          "404": {
            "description": "Registro de auditoria nao encontrado."
          },
          "401": {
            "description": "Token JWT ausente ou invalido."
          },
          "403": {
            "description": "Token sem scope ou merchant autorizado para o registro."
          },
          "400": {
            "description": "Request invalido.",
