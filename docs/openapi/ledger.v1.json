{
  "openapi": "3.0.4",
  "info": {
    "title": "Poc Arquitetura Ledger API",
    "description": "API em Clean Architecture com foco em DDD",
    "version": "1.0"
  },
  "servers": [
    {
      "url": "http://localhost:5226",
      "description": "Ambiente local direto do LedgerService.Api"
    }
  ],
  "paths": {
    "/api/v1/lancamentos": {
      "post": {
        "tags": [
          "Lancamentos"
        ],
        "summary": "Cria um lançamento no ledger.",
        "description": "Registra um lançamento CREDIT ou DEBIT. O endpoint exige `Idempotency-Key`, aceita `X-Correlation-Id` opcional, aplica limite de body configurável por `ApiLimits:MaxRequestBodySizeBytes` e retorna `409` quando a mesma chave de idempotência é reutilizada com payload diferente.\n\n<b>Autorização</b>: requer scope(s): <c>ledger.write</c>. (claim <c>scope</c> do JWT)",
        "operationId": "CreateLancamento",
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "description": "Chave de idempotência em formato UUID. Deve ser única por operação lógica.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Correlation-Id",
            "in": "header",
            "description": "Correlation id opcional em formato UUID. Se ausente, a API gera e devolve um valor no response header.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateLancamentoRequest"
              },
              "example": {
                "merchantId": "tese",
                "type": "CREDIT",
                "amount": 150,
                "description": "Venda do pedido 12345",
                "externalReference": "order-12345"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateLancamentoRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateLancamentoRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Lançamento criado com sucesso. Retorna Location com a URI canônica do recurso.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/LancamentoDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LancamentoDto"
                },
                "example": {
                  "id": "lan_9f3a1b2c",
                  "lancamentoId": "11111111-1111-1111-1111-111111111111",
                  "merchantId": "tese",
                  "type": "CREDIT",
                  "amount": "150.00",
                  "occurredAt": "2026-02-14T21:56:03.8825245-03:00",
                  "description": "Venda do pedido 12345",
                  "externalReference": "order-12345",
                  "createdAt": "2026-02-14T21:56:04.1023456-03:00"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/LancamentoDto"
                }
              }
            }
          },
          "400": {
            "description": "Request inválido.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                },
                "example": {
                  "type": "https://httpstatuses.com/400",
                  "title": "Invalid request",
                  "status": 400,
                  "detail": "One or more validation errors occurred.",
                  "errors": {
                    "amount": [
                      "Amount must have at most 18 digits and 2 decimal places."
                    ]
                  },
                  "correlationId": "5b7f7b2d-5bb5-49d2-918d-c5d87ff54e3d"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Conflito de idempotência.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "413": {
            "description": "Body acima do limite configurado.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "422": {
            "description": "Violação de regra de domínio.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "429": {
            "description": "Limite de requisições excedido."
          },
          "401": {
            "description": "Token ausente ou inválido."
          },
          "403": {
            "description": "Scope insuficiente ou token sem autorizacao para o merchant informado."
          },
          "500": {
            "description": "Erro interno.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        },
        "security": [
          {
            "Bearer": [ ]
          }
        ]
      }
    },
    "/api/v1/lancamentos/{lancamentoId}/estornos": {
      "post": {
        "tags": [
          "Lancamentos"
        ],
        "summary": "Solicita estorno de um lancamento.",
