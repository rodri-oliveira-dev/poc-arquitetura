          {
            "name": "X-Correlation-Id",
            "in": "header",
            "description": "Correlation id opcional em formato UUID. Se ausente, a API gera e devolve um valor no response header.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SolicitarEstornoLancamentoRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/SolicitarEstornoLancamentoRequest"
              }
            },
