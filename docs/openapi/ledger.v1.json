        "operationId": "SolicitarEstornoLancamento",
        "parameters": [
          {
            "name": "lancamentoId",
            "in": "path",
            "description": "Identificador interno do lancamento original.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "Idempotency-Key",
            "in": "header",
            "description": "Chave de idempotencia em formato UUID. Deve ser unica por operacao logica.",
