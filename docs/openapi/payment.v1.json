    "/api/v1/payments": {
      "post": {
        "tags": [
          "Payments"
        ],
        "summary": "Cria um payment externo.",
        "description": "Cria um Payment interno e solicita a criacao de uma intencao externa no provider configurado. A resposta sincrona nao confirma efeito financeiro final nem executa Ledger.\n\n<b>Autorizacao</b>: requer scope(s): <c>payment.write</c>. (claim <c>scope</c> do JWT)",
        "operationId": "CreatePayment",
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "description": "Chave de idempotencia em formato UUID. Deve ser unica por operacao logica.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Correlation-Id",
            "in": "header",
            "description": "Correlation id opcional em formato UUID. Se ausente, a API gera e devolve um valor no response header.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePaymentRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePaymentRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePaymentRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Payment aceito para confirmacao assincrona.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/CreatePaymentResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatePaymentResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatePaymentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Request invalido.",
