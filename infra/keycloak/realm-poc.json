{
  "realm": "poc",
  "enabled": true,
  "displayName": "POC Arquitetura",
  "registrationAllowed": false,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 600,
  "clients": [
    {
      "clientId": "ledger-api",
      "name": "LedgerService.Api audience",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false
    },
    {
      "clientId": "balance-api",
      "name": "BalanceService.Api audience",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false
    },
    {
      "clientId": "poc-automation",
      "name": "POC local automation",
      "description": "Client local descartavel para obter tokens via client_credentials.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "local_dev_client_secret",
      "clientAuthenticatorType": "client-secret",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": false,
      "defaultClientScopes": [
        "ledger.write",
        "ledger.read",
        "balance.read",
        "outbox.admin",
        "poc-api-audience",
        "poc-merchants"
      ],
      "optionalClientScopes": []
    },
    {
      "clientId": "poc-local-ledger-debug",
      "name": "POC local Ledger user debug",
      "description": "Client publico local descartavel para Direct Grant do usuario local_ledger_user.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": false,
      "defaultClientScopes": [
        "ledger.write",
        "ledger.read",
        "poc-api-audience",
        "poc-merchants"
      ],
      "optionalClientScopes": []
    },
    {
      "clientId": "poc-local-balance-debug",
      "name": "POC local Balance user debug",
      "description": "Client publico local descartavel para Direct Grant do usuario local_balance_user.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": false,
      "defaultClientScopes": [
        "balance.read",
        "poc-api-audience",
        "poc-merchants"
      ],
      "optionalClientScopes": []
    },
    {
      "clientId": "poc-local-admin-debug",
      "name": "POC local admin user debug",
      "description": "Client publico local descartavel para Direct Grant do usuario local_admin_user.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": false,
      "defaultClientScopes": [
        "ledger.write",
        "ledger.read",
        "balance.read",
        "outbox.admin",
        "poc-api-audience",
        "poc-merchants"
      ],
      "optionalClientScopes": []
    }
  ],
  "clientScopes": [
    {
      "name": "ledger.write",
      "description": "Permite criar lancamentos, estornos e reprocessamentos no Ledger.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "ledger.read",
      "description": "Permite consultar status de estornos e reprocessamentos no Ledger.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "balance.read",
      "description": "Permite consultar consolidados do Balance.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "outbox.admin",
      "description": "Permite operar endpoints administrativos de DLQ/Outbox.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "poc-api-audience",
      "description": "Adiciona audiences das APIs da POC ao access token.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "ledger-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "ledger-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "balance-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "balance-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "poc-merchants",
      "description": "Adiciona merchants autorizados para a POC local.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "merchant-id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "merchant_id",
            "claim.value": "tese m1",
            "jsonType.label": "String",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "local_ledger_user",
      "enabled": true,
      "firstName": "Local",
      "lastName": "Ledger Debug User",
      "email": "local_ledger_user@example.local",
      "emailVerified": false,
      "requiredActions": [],
      "attributes": {
        "debug_local_only": [
          "true"
        ],
        "purpose": [
          "Testar endpoints do LedgerService em desenvolvimento local."
        ],
        "expected_scopes": [
          "ledger.write ledger.read"
        ],
        "expected_merchant_id": [
          "tese m1"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "local_ledger_password",
          "temporary": false
        }
      ]
    },
    {
      "username": "local_balance_user",
      "enabled": true,
      "firstName": "Local",
      "lastName": "Balance Debug User",
      "email": "local_balance_user@example.local",
      "emailVerified": false,
      "requiredActions": [],
      "attributes": {
        "debug_local_only": [
          "true"
        ],
        "purpose": [
          "Testar endpoints do BalanceService em desenvolvimento local."
        ],
        "expected_scopes": [
          "balance.read"
        ],
        "expected_merchant_id": [
          "tese m1"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "local_balance_password",
          "temporary": false
        }
      ]
    },
    {
      "username": "local_admin_user",
      "enabled": true,
      "firstName": "Local",
      "lastName": "Admin Debug User",
      "email": "local_admin_user@example.local",
      "emailVerified": false,
      "requiredActions": [],
      "attributes": {
        "debug_local_only": [
          "true"
        ],
        "purpose": [
          "Facilitar debug local completo das APIs de negocio."
        ],
        "expected_scopes": [
          "ledger.write ledger.read balance.read outbox.admin"
        ],
        "expected_merchant_id": [
          "tese m1"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "local_admin_password",
          "temporary": false
        }
      ]
    }
  ]
}
