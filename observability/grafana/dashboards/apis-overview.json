      "tags": [],
      "targetBlank": false,
      "title": "Logs no Loki",
      "tooltip": "Abrir Explore com logs dos servicos selecionados.",
      "type": "link",
      "url": "/explore?orgId=1&left={\"datasource\":\"loki\",\"queries\":[{\"refId\":\"A\",\"expr\":\"{compose_project=\\\"poc-arquitetura\\\", environment=\\\"${environment}\\\", service=~\\\"${loki_service:regex}\\\"}\"}],\"range\":{\"from\":\"${__from}\",\"to\":\"${__to}\"}}"
    }
  ],
  "panels": [
    {
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "code": {
          "language": "plaintext",
          "showLineNumbers": false,
          "showMiniMap": false
        },
        "content": "Visao tecnica minima das APIs LedgerService.Api e BalanceService.Api usando metricas automaticas HTTP exportadas via OpenTelemetry Collector para Prometheus. Use o link Logs no Loki para abrir o Explore na mesma janela de tempo. Nao inclui metricas de negocio, Outbox, Kafka ou DLQ.",
        "mode": "markdown"
      },
      "pluginVersion": "12.3.0",
      "title": "Objetivo e limites",
      "type": "text"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Taxa de requisicoes HTTP recebidas por cada API.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (exported_job) (rate(http_server_request_duration_seconds_count{exported_job=~\"${service:regex}\"}[$__rate_interval]))",
          "legendFormat": "{{exported_job}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Requisicoes HTTP por servico",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Taxa de respostas HTTP 5xx por servico.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (exported_job, http_response_status_code) (rate(http_server_request_duration_seconds_count{exported_job=~\"${service:regex}\", http_response_status_code=~\"${status:regex}\"}[$__rate_interval]))",
          "legendFormat": "{{exported_job}} {{http_response_status_code}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Respostas HTTP por status",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Percentil 95 de duracao das requisicoes HTTP por servico.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (exported_job, le) (rate(http_server_request_duration_seconds_bucket{exported_job=~\"${service:regex}\"}[$__rate_interval])))",
          "legendFormat": "{{exported_job}} p95",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Latencia HTTP p95 por servico",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Taxa agregada por metodo e rota HTTP. Usa apenas rotas normalizadas pela instrumentacao ASP.NET Core.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "id": 5,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (exported_job, http_request_method, http_route) (rate(http_server_request_duration_seconds_count{exported_job=~\"${service:regex}\"}[$__rate_interval]))",
          "legendFormat": "{{exported_job}} {{http_request_method}} {{http_route}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Requisicoes por metodo e rota",
      "type": "timeseries"
    }
  ],
