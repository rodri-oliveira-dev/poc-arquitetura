      "id": 1,
      "options": {
        "code": {
          "language": "plaintext",
          "showLineNumbers": false,
          "showMiniMap": false
        },
        "content": "Visao tecnica minima das APIs Auth.Api, LedgerService.Api e BalanceService.Api usando metricas automaticas HTTP exportadas via OpenTelemetry Collector para Prometheus. Nao inclui metricas de negocio, Outbox, Kafka ou DLQ.",
        "mode": "markdown"
      },
      "pluginVersion": "12.3.0",
      "title": "Objetivo e limites",
      "type": "text"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Taxa de requisicoes HTTP recebidas por cada API.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (exported_job) (rate(http_server_request_duration_seconds_count{exported_job=~\"Auth.Api|LedgerService.Api|BalanceService.Api\"}[$__rate_interval]))",
          "legendFormat": "{{exported_job}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Requisicoes HTTP por servico",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Taxa de respostas HTTP 5xx por servico.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (exported_job) (rate(http_server_request_duration_seconds_count{exported_job=~\"Auth.Api|LedgerService.Api|BalanceService.Api\", http_response_status_code=~\"5..\"}[$__rate_interval]))",
          "legendFormat": "{{exported_job}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Erros HTTP 5xx por servico",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Percentil 95 de duracao das requisicoes HTTP por servico.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (exported_job, le) (rate(http_server_request_duration_seconds_bucket{exported_job=~\"Auth.Api|LedgerService.Api|BalanceService.Api\"}[$__rate_interval])))",
          "legendFormat": "{{exported_job}} p95",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Latencia HTTP p95 por servico",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Taxa agregada por metodo e rota HTTP. Usa apenas rotas normalizadas pela instrumentacao ASP.NET Core.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "id": 5,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (exported_job, http_request_method, http_route) (rate(http_server_request_duration_seconds_count{exported_job=~\"Auth.Api|LedgerService.Api|BalanceService.Api\"}[$__rate_interval]))",
          "legendFormat": "{{exported_job}} {{http_request_method}} {{http_route}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Requisicoes por metodo e rota",
      "type": "timeseries"
    }
