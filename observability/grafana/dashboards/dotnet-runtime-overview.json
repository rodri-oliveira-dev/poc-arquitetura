  "panels": [
    {
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "code": {
          "language": "plaintext",
          "showLineNumbers": false,
          "showMiniMap": false
        },
        "content": "Visao tecnica minima do runtime .NET das APIs usando metricas automaticas System.Runtime exportadas via OpenTelemetry. Os paineis ajudam a observar memoria, GC, ThreadPool e excecoes sem metricas customizadas.",
        "mode": "markdown"
      },
      "pluginVersion": "12.3.0",
      "title": "Objetivo e limites",
      "type": "text"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Working set do processo .NET por API.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "max by (exported_job) (dotnet_process_memory_working_set_bytes{exported_job=~\"Auth.Api|LedgerService.Api|BalanceService.Api\"})",
          "legendFormat": "{{exported_job}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Memoria do processo por servico",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Taxa de coletas de GC por geracao e servico.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (exported_job, gc_heap_generation) (rate(dotnet_gc_collections_total{exported_job=~\"Auth.Api|LedgerService.Api|BalanceService.Api\"}[$__rate_interval]))",
          "legendFormat": "{{exported_job}} {{gc_heap_generation}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Coletas de GC por geracao",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Tamanho da fila do ThreadPool por API.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "max by (exported_job) (dotnet_thread_pool_queue_length_total{exported_job=~\"Auth.Api|LedgerService.Api|BalanceService.Api\"})",
          "legendFormat": "{{exported_job}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Fila do ThreadPool por servico",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Taxa de excecoes observadas pelo runtime .NET, agregada por tipo estavel de excecao.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "id": 5,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (exported_job, error_type) (rate(dotnet_exceptions_total{exported_job=~\"Auth.Api|LedgerService.Api|BalanceService.Api\"}[$__rate_interval]))",
          "legendFormat": "{{exported_job}} {{error_type}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Excecoes do runtime por tipo",
      "type": "timeseries"
    }
