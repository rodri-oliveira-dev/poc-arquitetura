{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "Swagger": {
        "Enabled": false
    },
    "Observability": {
        "OpenTelemetry": {
            "Enabled": false,
            "UseConsoleExporter": false,
            "ServiceName": "Auth.Api"
        }
    },
    "Auth": {
        "Issuer": "https://auth-api",
        "Audiences": [
            "ledger-api",
            "balance-api"
        ],
        "AuthorizedMerchants": [
            "tese",
            "m1"
        ],
        "TokenLifetimeMinutes": 10,
        "KeyPath": "./data/keys/auth-rsa-key.json"
    }
}
