{
  "Jwt": {
    "Issuer": "https://auth-api",
    "Audience": "balance-api",
    "JwksUrl": "http://localhost:5030/.well-known/jwks.json"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=127.0.0.1;Port=5433;Database=dbBalance;Username=userBalance;Password=Balance123"
  },
  "Kafka": {
    "Consumer": {
      "BootstrapServers": "127.0.0.1:9092",
      "GroupId": "ledger-service-consumer",
      "ClientId": "ledger-service-consumer-1",
      "AutoOffsetReset": "Earliest",
      "EnableAutoCommit": false,
      "EnableAutoOffsetStore": false,
      "AllowAutoCreateTopics": false,
      "InvalidMessageRetryDelay": "00:00:02",
      "ConsumeErrorRetryDelay": "00:00:02",
      "ProcessingErrorRetryDelay": "00:00:05",
      "Topics": [
        "ledger.ledgerentry.created"
      ]
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Console": {
      "IncludeScopes": true
    }
  },
  "Observability": {
    "OpenTelemetry": {
      "Enabled": false,
      "UseConsoleExporter": false,
      "ServiceName": "BalanceService.Api"
    }
  },
  "AllowedHosts": "*"
}
