{
  "Swagger": {
    "Enabled": false
  },
  "ApiLimits": {
    "MaxRequestBodySizeBytes": 1048576,
    "MaxBalancePeriodDays": 31,
    "RateLimitPermitLimit": 100,
    "RateLimitWindowSeconds": 60,
    "RateLimitQueueLimit": 10
  },
  "Jwt": {
    "Issuer": "https://auth-api",
    "Audience": "balance-api",
    "JwksUrl": "http://localhost:5030/.well-known/jwks.json",
    "RequireHttpsMetadata": true,
    "JwksTimeoutSeconds": 5,
    "JwksRetryCount": 2,
    "JwksRetryBaseDelayMilliseconds": 200
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=127.0.0.1;Port=5433;Database=dbBalance;Username=userBalance;Password=local_dev_password"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Console": {
      "IncludeScopes": true
    }
  },
  "Observability": {
    "OpenTelemetry": {
      "Enabled": false,
      "UseConsoleExporter": false,
      "OtlpEndpoint": "",
      "ServiceName": "BalanceService.Api"
    }
  },
  "AllowedHosts": "*"
}
