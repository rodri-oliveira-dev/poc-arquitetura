{
  "ConnectionStrings": {
    "DefaultConnection": "Host=127.0.0.1;Port=5433;Database=dbBalance;Username=userBalance;Password=Balance123"
  },
  "Kafka": {
    "Producer": {
      "BootstrapServers": "127.0.0.1:9092",
      "ClientId": "Balance-service",
      "Acks": "all",
      "EnableIdempotence": true,
      "DefaultTopic": "Balance-events",
      "TopicMap": {
        "BalanceEntryCreated": "Balance.Balanceentry.created"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Console": {
      "IncludeScopes": true
    }
  },
  "Observability": {
    "OpenTelemetry": {
      "Enabled": false,
      "UseConsoleExporter": false,
      "ServiceName": "BalanceService.Api"
    }
  },
  "AllowedHosts": "*"
}
