{
  "ConnectionStrings": {
    "DefaultConnection": "Host=127.0.0.1;Port=15433;Database=dbBalance;Username=userBalance;Password=local_dev_password"
  },
  "Messaging": {
    "Provider": "Kafka"
  },
  "Kafka": {
    "Enabled": true,
    "Consumer": {
      "BootstrapServers": "127.0.0.1:9092",
      "GroupId": "balance-service-consumer",
      "ClientId": "balance-service-consumer-1",
      "SecurityProtocol": "Plaintext",
      "AutoOffsetReset": "Earliest",
      "EnableAutoCommit": false,
      "EnableAutoOffsetStore": false,
      "AllowAutoCreateTopics": false,
      "InvalidMessageRetryDelay": "00:00:02",
      "ConsumeErrorRetryDelay": "00:00:02",
      "ProcessingErrorRetryDelay": "00:00:05",
      "DeadLetterTopic": "ledger.ledgerentry.created.dlq",
      "DeadLetterMessageTimeoutMs": 30000,
      "Topics": [
        "ledger.ledgerentry.created"
      ]
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "Console": {
      "IncludeScopes": true
    }
  },
  "Observability": {
    "OpenTelemetry": {
      "Enabled": false,
      "UseConsoleExporter": false,
      "OtlpEndpoint": "",
      "ServiceName": "BalanceService.Worker"
    }
  }
}
