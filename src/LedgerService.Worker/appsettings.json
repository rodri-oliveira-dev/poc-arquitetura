{
  "ConnectionStrings": {
    "DefaultConnection": "Host=127.0.0.1;Port=5432;Database=appdb;Username=appuser;Password=local_dev_password"
  },
  "Messaging": {
    "Provider": "PubSub"
  },
  "PubSub": {
    "Enabled": true,
    "Producer": {
      "ProjectId": "poc-local",
      "DefaultTopicId": "ledger.ledgerentry.created.local",
      "EnableMessageOrdering": false,
      "TopicMap": {
        "LedgerEntryCreated.v1": "ledger.ledgerentry.created.local"
      }
    }
  },
  "Kafka": {
    "Enabled": true,
    "Producer": {
      "BootstrapServers": "127.0.0.1:9092",
      "ClientId": "ledger-worker",
      "SecurityProtocol": "Plaintext",
      "Acks": "all",
      "EnableIdempotence": true,
      "DefaultTopic": "ledger-events",
      "TopicMap": {
        "LedgerEntryCreated.v1": "ledger.ledgerentry.created",
        "LancamentoEstornoSolicitado.v1": "ledger.lancamento.estorno.solicitado",
        "ReprocessamentoLancamentosSolicitado.v1": "ledger.lancamentos.reprocessamento.solicitado"
      }
    }
  },
  "Outbox": {
    "Publisher": {
      "PollingIntervalSeconds": 5,
      "BatchSize": 50,
      "MaxParallelism": 4,
      "MaxAttempts": 10,
      "BaseBackoffSeconds": 5,
      "LockDurationSeconds": 60
    }
  },
  "Estornos": {
    "Processor": {
      "Enabled": true,
      "PollingIntervalSeconds": 5,
      "BatchSize": 10
    }
  },
  "Reprocessamentos": {
    "Consumer": {
      "Enabled": true,
      "BootstrapServers": "127.0.0.1:9092",
      "GroupId": "ledger-reprocessamento-consumer",
      "ClientId": "ledger-reprocessamento-consumer-1",
      "SecurityProtocol": "Plaintext",
      "Topic": "ledger.lancamentos.reprocessamento.solicitado",
      "AutoOffsetReset": "Earliest",
      "EnableAutoCommit": false,
      "EnableAutoOffsetStore": false,
      "AllowAutoCreateTopics": false,
      "ConsumeErrorRetryDelay": "00:00:02",
      "ProcessingErrorRetryDelay": "00:00:05"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "Console": {
      "IncludeScopes": true
    }
  },
  "Observability": {
    "OpenTelemetry": {
      "Enabled": false,
      "UseConsoleExporter": false,
      "OtlpEndpoint": "",
      "ServiceName": "LedgerService.Worker"
    }
  }
}
