{
  "Swagger": {
    "Enabled": false
  },
  "Cors": {
    "Enabled": false,
    "AllowedOrigins": [],
    "AllowedMethods": [],
    "AllowedHeaders": [],
    "ExposedHeaders": [],
    "AllowCredentials": false,
    "PreflightMaxAgeSeconds": null
  },
  "ApiLimits": {
    "MaxRequestBodySizeBytes": 1048576,
    "MaxBalancePeriodDays": 31,
    "RateLimitPermitLimit": 100,
    "RateLimitWindowSeconds": 60,
    "RateLimitQueueLimit": 10
  },
  "Jwt": {
    "Issuer": "http://localhost:8081/realms/poc",
    "Audience": "balance-api",
    "JwksUrl": "http://localhost:8081/realms/poc/protocol/openid-connect/certs",
    "RequireHttpsMetadata": true,
    "JwksTimeoutSeconds": 5,
    "JwksRetryCount": 2,
    "JwksRetryBaseDelayMilliseconds": 200
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=127.0.0.1;Port=15432;Database=appdb;Username=balance_read_user;Password=<BALANCE_DB_READ_PASSWORD>"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Console": {
      "IncludeScopes": true
    }
  },
  "Observability": {
    "OpenTelemetry": {
      "Enabled": false,
      "UseConsoleExporter": false,
      "OtlpEndpoint": "",
      "ServiceName": "BalanceService.Api"
    }
  },
  "AllowedHosts": "*"
}
