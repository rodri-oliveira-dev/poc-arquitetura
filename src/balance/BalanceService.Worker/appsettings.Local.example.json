{
  "ConnectionStrings": {
    "DefaultConnection": "Host=127.0.0.1;Port=15432;Database=appdb;Username=balance_write_user;Password=<BALANCE_DB_WRITE_PASSWORD>"
  },
  "Messaging": {
    "Provider": "Kafka"
  },
  "PubSub": {
    "Enabled": true,
    "Consumer": {
      "ProjectId": "poc-local",
      "SubscriptionId": "balance-service-ledger-events-local",
      "DeadLetterTopicId": "ledger.ledgerentry.created.dlq.local",
      "EnableExactlyOnceDelivery": false,
      "AckDeadlineSeconds": 60,
      "ProcessingErrorRetryDelay": "00:00:05"
    }
  },
  "Kafka": {
    "Consumer": {
      "BootstrapServers": "127.0.0.1:19092",
      "SecurityProtocol": "Plaintext"
    }
  }
}
