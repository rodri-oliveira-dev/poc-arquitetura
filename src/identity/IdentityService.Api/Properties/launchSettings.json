{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "http": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "applicationUrl": "http://localhost:5232",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "IdentityProvider__Keycloak__ClientId": "identity-service-admin",
        "IdentityProvider__Keycloak__ClientSecret": "<KEYCLOAK_CLIENT_SECRET>",
        "Email__Provider": "Mailpit",
        "Mailpit__Host": "localhost",
        "Mailpit__Port": "1025"
      }
    },
    "https": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "applicationUrl": "https://localhost:7232;http://localhost:5232",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "IdentityProvider__Keycloak__ClientId": "identity-service-admin",
        "IdentityProvider__Keycloak__ClientSecret": "<KEYCLOAK_CLIENT_SECRET>",
        "Email__Provider": "Mailpit",
        "Mailpit__Host": "localhost",
        "Mailpit__Port": "1025"
      }
    }
  }
}
