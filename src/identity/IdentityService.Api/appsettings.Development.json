{
  "Cors": {
    "Enabled": true,
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "https://localhost:3001",
      "https://localhost:5173"
    ],
    "AllowedMethods": [
      "GET",
      "POST",
      "PUT",
      "PATCH",
      "DELETE"
    ],
    "AllowedHeaders": [
      "Authorization",
      "Content-Type",
      "Idempotency-Key",
      "X-Correlation-Id"
    ],
    "ExposedHeaders": [
      "X-Correlation-Id"
    ],
    "AllowCredentials": false,
    "PreflightMaxAgeSeconds": 600
  },
  "Email": {
    "Provider": "Mailpit"
  },
  "Mailpit": {
    "Host": "localhost",
    "Port": 1025,
    "EnableSsl": false,
    "From": "noreply@poc-arquitetura.local",
    "FromName": "POC Arquitetura"
  }
}
