{
  "ConnectionStrings": {
    "DefaultConnection": "Host=127.0.0.1;Port=15432;Database=appdb;Username=identity_app_user;Password=<IDENTITY_DB_PASSWORD>"
  },
  "Jwt": {
    "Issuer": "http://localhost:8081/realms/poc",
    "Audience": "identity-api",
    "JwksUrl": "http://localhost:8081/realms/poc/protocol/openid-connect/certs",
    "RequireHttpsMetadata": false
  },
  "IdentityProvider": {
    "Keycloak": {
      "BaseUrl": "http://localhost:8081",
      "Realm": "poc",
      "TokenEndpoint": "/realms/poc/protocol/openid-connect/token",
      "ClientId": "",
      "ClientSecret": "",
      "Timeout": "00:00:10",
      "CompensationTimeout": "00:00:05"
    }
  },
  "IdentityService": {
    "CreateUserConsistency": {
      "CompensationTimeout": "00:00:05"
    }
  },
  "Email": {
    "Provider": "Resend",
    "TemplatePath": "Email/Templates/WelcomeEmail.html",
    "AuthenticationUrl": ""
  },
  "Mailpit": {
    "Host": "localhost",
    "Port": 1025,
    "EnableSsl": false,
    "From": "noreply@poc-arquitetura.local",
    "FromName": "POC Arquitetura"
  },
  "Resend": {
    "ApiKey": "",
    "From": "onboarding@resend.dev",
    "FromName": "POC Arquitetura",
    "ReplyTo": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
