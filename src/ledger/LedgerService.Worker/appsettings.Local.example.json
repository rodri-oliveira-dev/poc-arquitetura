{
  "ConnectionStrings": {
    "DefaultConnection": "Host=127.0.0.1;Port=15432;Database=appdb;Username=ledger_app_user;Password=<LEDGER_DB_PASSWORD>"
  },
  "Messaging": {
    "Provider": "Kafka"
  },
  "PubSub": {
    "Enabled": true,
    "Producer": {
      "ProjectId": "poc-local",
      "DefaultTopicId": "ledger.ledgerentry.created.local",
      "EnableMessageOrdering": false,
      "TopicMap": {
        "LedgerEntryCreated.v1": "ledger.ledgerentry.created.local",
        "LedgerEntryCreated.v2": "ledger.ledgerentry.created.local"
      }
    }
  },
  "Kafka": {
    "Producer": {
      "BootstrapServers": "127.0.0.1:19092",
      "SecurityProtocol": "Plaintext"
    }
  },
  "Reprocessamentos": {
    "Consumer": {
      "BootstrapServers": "127.0.0.1:19092",
      "SecurityProtocol": "Plaintext"
    }
  }
}
