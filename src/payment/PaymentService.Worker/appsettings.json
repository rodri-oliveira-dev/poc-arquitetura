{
  "ConnectionStrings": {
    "DefaultConnection": "Host=127.0.0.1;Port=15432;Database=appdb;Username=payment_app_user;Password=<PAYMENT_DB_PASSWORD>"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "PaymentService": {
    "InboxWorker": {
      "PollingInterval": "00:00:02",
      "BatchSize": 20,
      "MaxRetryCount": 5,
      "BaseRetryDelay": "00:00:05",
      "MaxRetryDelay": "00:05:00",
      "ProcessingLeaseTimeout": "00:01:00"
    }
  },
  "Observability": {
    "OpenTelemetry": {
      "Enabled": false,
      "UseConsoleExporter": false,
      "OtlpEndpoint": "",
      "ServiceName": "PaymentService.Worker"
    }
  }
}
