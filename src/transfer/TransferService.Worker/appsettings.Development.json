{
  "ConnectionStrings": {
    "DefaultConnection": "Host=127.0.0.1;Port=15432;Database=appdb;Username=transfer_app_user;Password=<TRANSFER_DB_PASSWORD>"
  },
  "Messaging": {
    "Provider": "Kafka"
  },
  "TransferService": {
    "Worker": {
      "Kafka": {
        "BootstrapServers": "127.0.0.1:19092",
        "ClientId": "transfer-service-worker-local",
        "SecurityProtocol": "Plaintext"
      },
      "Ledger": {
        "BaseAddress": "http://localhost:5226",
        "Auth": {
          "TokenEndpoint": "http://localhost:8081/realms/poc/protocol/openid-connect/token",
          "ClientId": "poc-automation",
          "ClientSecret": "<KEYCLOAK_CLIENT_SECRET>",
          "Scope": "ledger.write"
        }
      }
    }
  },
  "OpenTelemetry": {
    "Enabled": false
  }
}
