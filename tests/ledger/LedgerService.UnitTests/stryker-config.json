{
  "stryker-config": {
    "solution": "../../../LedgerService.slnx",
    "project": "LedgerService.Application.csproj",
    "mutation-level": "Standard",
    "coverage-analysis": "perTest",
    "reporters": [
      "progress",
      "html",
      "json"
    ],
    "mutate": [
      "**/*.cs",
      "!**/bin/**",
      "!**/obj/**",
      "!**/*.Generated.cs",
      "!**/*.g.cs",
      "!**/*.g.*.cs"
    ],
    "thresholds": {
      "high": 80,
      "low": 60,
      "break": 0
    }
  }
}
